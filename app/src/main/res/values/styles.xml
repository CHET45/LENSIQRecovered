<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ActionSheetDialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">#00000000</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    <style name="ActivityTranslucent" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="AppTheme" parent="@style/Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowBackground">@color/app_background_color_bg</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:navigationBarColor">@color/app_background_color_bg</item>
        <item name="aiEmptyIcon">@null</item>
        <item name="base_purple">@color/base_purple</item>
        <item name="colorAccent">@color/app_base_color</item>
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryDark">@color/app_background_color_bg</item>
        <item name="dialog_bg">@drawable/dialog_bg</item>
        <item name="dialog_lines">@color/dialog_line</item>
        <item name="homeBg">@drawable/app_bg</item>
        <item name="imgbg">@color/base_blue</item>
        <item name="mineLoginIcon">@color/transparent</item>
        <item name="shape_add_device_bg">@drawable/shape_add_device_bg</item>
        <item name="shape_un_add_device_bg">@drawable/shape_un_add_device_bg</item>
        <item name="text_important_color">@color/text_important_color_new</item>
        <item name="voiceEmptyIcon">@drawable/ic_voice_note</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="BottomToTopAnim">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>
    <style name="CustomCaptureTheme" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>
    <style name="CustomDialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
    <style name="CustomDialogTheme" parent="@style/Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowActionBar">false</item>
    </style>
    <style name="CustomSeekBar" parent="@style/Widget.AppCompat.SeekBar">
        <item name="android:progressDrawable">@drawable/custom_progress_bar</item>
        <item name="android:thumb">@drawable/custom_thumb</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
    </style>
    <style name="DefaultNumberPickerTheme" parent="@style/AppTheme">
        <item name="android:textColor">@android:color/white</item>
        <item name="colorControlNormal">@color/white</item>
    </style>
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>
    <style name="DialogWindowTheme">
        <item name="android:windowClipToOutline">false</item>
    </style>
    <style name="DraggableTranslucentTheme" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/image_view_bg_color</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
    <style name="EarjoyDialog" parent="@android:style/Theme.DeviceDefault.Dialog.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:background">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="FloatingDialogTheme">
        <item name="android:windowIsFloating">false</item>
    </style>
    <style name="FloatingDialogWindowTheme">
        <item name="android:dialogTheme">@style/FloatingDialogTheme</item>
        <item name="android:windowClipToOutline">false</item>
    </style>
    <style name="NoAnimationTheme" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowExitAnimation">@anim/no_animation</item>
    </style>
    <style name="PermissionXDefaultDialog" parent="@style/Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="TextStyle_13sp_black_333333">
        <item name="android:textSize">@dimen/text_13sp</item>
        <item name="android:textColor">@color/black</item>
    </style>
    <style name="Theme.Hidden" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="customDialog" parent="@android:style/Theme.Dialog">
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@drawable/dialog_bg</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="custom_dialog" parent="@android:style/Theme.Dialog">
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="custom_new_dialog" parent="@android:style/Theme.Dialog">
        <item name="android:backgroundDimAmount">0</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="permission_dialog" parent="@android:style/Theme.Dialog">
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
    <style name="searchNoteDialog" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="colorPrimaryDark">@color/transparent</item>
    </style>
    <style name="textBlack">
        <item name="android:fontFamily">sans-serif-black</item>
    </style>
    <style name="textLight">
        <item name="android:fontFamily">sans-serif-light</item>
    </style>
    <style name="textMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="textRegular">
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="textThin">
        <item name="android:fontFamily">sans-serif-thin</item>
    </style>
    <style name="toolsTextAppearance" parent="@style/textMedium">
        <item name="android:textSize">@dimen/text_18sp</item>
    </style>
    <style name="watchfun_dialog_anim" parent="@android:style/Animation">
        <item name="android:windowEnterAnimation">@anim/watchfun_dialog_show</item>
        <item name="android:windowExitAnimation">@anim/watchfun_dialog_dismiss</item>
    </style>
    <style name="zxing_CaptureTheme" parent="@android:style/Theme.Holo.NoActionBar.Fullscreen"/>
</resources>
