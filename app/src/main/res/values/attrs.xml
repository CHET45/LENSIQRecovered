<?xml version="1.0" encoding="utf-8"?>

<resources>
    <!-- Note record progress attrs -->
    <attr name="ballColor" format="color" />
    <attr name="progressColor" format="color" />
    <attr name="progressBgColor" format="color" />

    <!-- Circle/photo/video/audio progress attrs -->
    <attr name="progress_width" format="dimension" />
    <attr name="progress_color" format="color" />

    <attr name="location_start">
        <enum name="left" value="1" />
        <enum name="top" value="2" />
        <enum name="right" value="3" />
        <enum name="bottom" value="4" />
    </attr>
    <!-- Existing app theme attrs -->
    <attr name="aiEmptyIcon" format="reference" />
    <attr name="base_purple" format="reference|color" />
    <attr name="dialog_bg" format="reference" />
    <attr name="dialog_lines" format="reference|color" />
    <attr name="homeBg" format="reference" />
    <attr name="imgbg" format="reference|color" />
    <attr name="mineLoginIcon" format="reference|color" />
    <attr name="shape_add_device_bg" format="reference" />
    <attr name="shape_un_add_device_bg" format="reference" />
    <attr name="text_important_color" format="reference|color" />
    <attr name="voiceEmptyIcon" format="reference" />
    <attr name="voiceIcon" format="reference" />

    <!-- Generic rounded custom views -->
    <attr name="radius" format="dimension|reference" />

    <!-- CalendarLayout / CalendarView attrs -->
    <attr name="calendar_show_mode">
        <enum name="both_month_week_view" value="0" />
        <enum name="only_week_view" value="1" />
        <enum name="only_month_view" value="2" />
    </attr>

    <attr name="month_view_show_mode">
        <enum name="mode_all" value="0" />
        <enum name="mode_only_current" value="1" />
        <enum name="mode_fix" value="2" />
    </attr>

    <attr name="calendar_height" format="dimension|reference" />
    <attr name="month_view" format="string|reference" />
    <attr name="week_view" format="string|reference" />
    <attr name="week_bar_view" format="string|reference" />
    <attr name="week_background" format="color|reference" />
    <attr name="week_text_color" format="color|reference" />
    <attr name="week_text_size" format="dimension|reference" />
    <attr name="day_text_size" format="dimension|reference" />

    <declare-styleable name="CalendarLayout">
        <attr name="calendar_show_mode" />
    </declare-styleable>

    <declare-styleable name="CalendarView">
        <attr name="calendar_height" />
        <attr name="month_view" />
        <attr name="week_view" />
        <attr name="week_bar_view" />
        <attr name="week_background" />
        <attr name="week_text_color" />
        <attr name="week_text_size" />
        <attr name="day_text_size" />
        <attr name="month_view_show_mode" />
    </declare-styleable>

    <!-- VerificationCodeView attrs -->
    <attr name="vcv_et_number" format="integer" />

    <attr name="vcv_et_inputType">
        <enum name="number" value="0" />
        <enum name="numberPassword" value="1" />
        <enum name="text" value="2" />
        <enum name="textPassword" value="3" />
    </attr>

    <attr name="vcv_et_width" format="dimension|reference" />
    <attr name="vcv_et_height" format="dimension|reference" />
    <attr name="vcv_et_text_color" format="color|reference" />
    <attr name="vcv_et_text_size" format="dimension|reference" />
    <attr name="vcv_et_bg" format="reference" />
    <attr name="vcv_et_cursor" format="reference" />
    <attr name="vcv_et_cursor_visible" format="boolean" />
    <attr name="vcv_et_spacing" format="dimension|reference" />

    <!-- The original library uses this typo: vericationCodeView -->
    <declare-styleable name="vericationCodeView">
        <attr name="vcv_et_number" />
        <attr name="vcv_et_inputType" />
        <attr name="vcv_et_width" />
        <attr name="vcv_et_height" />
        <attr name="vcv_et_text_color" />
        <attr name="vcv_et_text_size" />
        <attr name="vcv_et_bg" />
        <attr name="vcv_et_cursor" />
        <attr name="vcv_et_cursor_visible" />
        <attr name="vcv_et_spacing" />
    </declare-styleable>

    <declare-styleable name="VerificationCodeView">
        <attr name="vcv_et_number" />
        <attr name="vcv_et_inputType" />
        <attr name="vcv_et_width" />
        <attr name="vcv_et_height" />
        <attr name="vcv_et_text_color" />
        <attr name="vcv_et_text_size" />
        <attr name="vcv_et_bg" />
        <attr name="vcv_et_cursor" />
        <attr name="vcv_et_cursor_visible" />
        <attr name="vcv_et_spacing" />
    </declare-styleable>

    <!-- BottomBarLayout / BottomBarItem attrs -->
    <attr name="iconNormal" format="reference" />
    <attr name="iconSelected" format="reference" />
    <attr name="itemText" format="string|reference" />
    <attr name="itemTextSize" format="dimension|reference" />
    <attr name="itemTextBold" format="boolean" />
    <attr name="textColorNormal" format="color|reference" />
    <attr name="textColorSelected" format="color|reference" />
    <attr name="itemMarginTop" format="dimension|reference" />
    <attr name="openTouchBg" format="boolean" />
    <attr name="touchDrawable" format="reference" />
    <attr name="iconWidth" format="dimension|reference" />
    <attr name="iconHeight" format="dimension|reference" />
    <attr name="itemPadding" format="dimension|reference" />
    <attr name="unreadTextSize" format="dimension|reference" />
    <attr name="unreadTextColor" format="color|reference" />
    <attr name="unreadTextBg" format="reference" />
    <attr name="msgTextSize" format="dimension|reference" />
    <attr name="msgTextColor" format="color|reference" />
    <attr name="msgTextBg" format="reference" />
    <attr name="notifyPointBg" format="reference" />
    <attr name="unreadThreshold" format="integer" />

    <declare-styleable name="BottomBarItem">
        <attr name="iconNormal" />
        <attr name="iconSelected" />
        <attr name="itemText" />
        <attr name="itemTextSize" />
        <attr name="itemTextBold" />
        <attr name="textColorNormal" />
        <attr name="textColorSelected" />
        <attr name="itemMarginTop" />
        <attr name="openTouchBg" />
        <attr name="touchDrawable" />
        <attr name="iconWidth" />
        <attr name="iconHeight" />
        <attr name="itemPadding" />
        <attr name="unreadTextSize" />
        <attr name="unreadTextColor" />
        <attr name="unreadTextBg" />
        <attr name="msgTextSize" />
        <attr name="msgTextColor" />
        <attr name="msgTextBg" />
        <attr name="notifyPointBg" />
        <attr name="unreadThreshold" />
    </declare-styleable>

</resources>