<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="@dimen/dp_20"
        app:layout_constraintBottom_toTopOf="@+id/btn_unpair"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_24">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/text_important_color_new"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_16"
                    android:text="@string/string_device_base_setting"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_btn_main"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_video_direction_layout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/set_text_size"
                            android:textColor="@color/color_main_text"
                            android:gravity="center_vertical"
                            android:id="@+id/tv_video_direction"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/ad_icon_height"
                            android:text="@string/string_takepicture_mode"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/set_button_text_padding_right"
                            android:layout_alignParentStart="true"/>
                        <TextView
                            android:textSize="@dimen/tablayout_text_size"
                            android:textColor="@color/white_8F8F8F"
                            android:ellipsize="end"
                            android:gravity="end|center_vertical"
                            android:id="@+id/tv_direction_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:drawablePadding="@dimen/dp_10"
                            android:layout_centerVertical="true"
                            android:drawableEnd="@drawable/ic_bv_more"
                            android:paddingStart="@dimen/set_button_text_padding_left"
                            android:paddingEnd="@dimen/dp_20"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_toEndOf="@+id/tv_video_direction"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:id="@+id/line_video_direction"
                        android:background="@color/color_line"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_video_duration_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/set_text_size"
                            android:textColor="@color/color_main_text"
                            android:gravity="center_vertical"
                            android:id="@+id/tv_video_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/ad_icon_height"
                            android:text="@string/string_device_video_duration"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/set_button_text_padding_right"
                            android:layout_alignParentStart="true"/>
                        <TextView
                            android:textSize="@dimen/tablayout_text_size"
                            android:textColor="@color/white_8F8F8F"
                            android:ellipsize="end"
                            android:gravity="end|center_vertical"
                            android:id="@+id/tv_duration_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:drawablePadding="@dimen/dp_10"
                            android:layout_centerVertical="true"
                            android:drawableEnd="@drawable/ic_bv_more"
                            android:paddingStart="@dimen/set_button_text_padding_left"
                            android:paddingEnd="@dimen/dp_20"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_toEndOf="@+id/tv_video_duration"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:id="@+id/line_video_duration"
                        android:background="@color/color_line"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/color_main_text"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_system_volume"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ad_icon_height"
                        android:text="@string/string_device_system_volume"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                    <View
                        android:id="@+id/line_system_volume"
                        android:background="@color/color_line"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_wear_layout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/ad_icon_height"
                            android:layout_toStartOf="@+id/iv_wear_switch">
                            <TextView
                                android:textSize="@dimen/set_text_size"
                                android:textColor="@color/color_main_text"
                                android:id="@+id/tv_wear"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_device_wear"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                            <TextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/text_important_color_new"
                                android:id="@+id/tv_wear_tip"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_device_wear_tip"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                        </LinearLayout>
                        <ImageView
                            android:id="@+id/iv_wear_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_unselect"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:id="@+id/line_wear_layout"
                        android:background="@color/color_line"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_water_mask"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/ad_icon_height"
                            android:layout_toStartOf="@+id/iv_water_mask_switch">
                            <TextView
                                android:textSize="@dimen/set_text_size"
                                android:textColor="@color/color_main_text"
                                android:id="@+id/tv_water_mask"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_water_mask"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                        </LinearLayout>
                        <ImageView
                            android:id="@+id/iv_water_mask_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_unselect"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/color_main_text"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_gesture"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ad_icon_height"
                        android:text="@string/string_device_gesture"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                    <View
                        android:background="@color/color_line"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_video_stabilizer"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_65">
                        <TextView
                            android:textSize="@dimen/set_text_size"
                            android:textColor="@color/color_main_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/video_stabilization"
                            android:layout_centerVertical="true"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/set_button_text_padding_right"/>
                        <ImageView
                            android:id="@+id/iv_video_stabilizer_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_select"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/color_line"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_image_upscale"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_65">
                        <TextView
                            android:textSize="@dimen/set_text_size"
                            android:textColor="@color/color_main_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/image_upscale"
                            android:layout_centerVertical="true"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/set_button_text_padding_right"/>
                        <ImageView
                            android:id="@+id/iv_image_upscale_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_select"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                </LinearLayout>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/text_important_color_new"
                    android:id="@+id/tv_ai_title"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_24"
                    android:layout_marginBottom="@dimen/dp_16"
                    android:text="@string/string_setting_ai"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/ll_speech_layout"
                    android:background="@drawable/bg_btn_main"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_wakeup_layout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/ad_icon_height"
                            android:layout_toStartOf="@+id/iv_wakeup_switch">
                            <TextView
                                android:textSize="@dimen/set_text_size"
                                android:textColor="@color/color_main_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_setting_ai_wakeup"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                            <TextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/text_important_color_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_setting_ai_wakeup_tip"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                        </LinearLayout>
                        <ImageView
                            android:id="@+id/iv_wakeup_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_unselect"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:id="@+id/line_wakeup"
                        android:background="@color/color_line"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/rl_offline_layout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/ad_icon_height"
                            android:layout_toStartOf="@+id/iv_offline_switch">
                            <TextView
                                android:textSize="@dimen/set_text_size"
                                android:textColor="@color/color_main_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_offline_voice"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                            <TextView
                                android:textSize="@dimen/sp_12"
                                android:textColor="@color/text_important_color_new"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_offline_voice_tip"
                                android:paddingStart="@dimen/dp_15"
                                android:paddingEnd="@dimen/set_button_text_padding_right"/>
                        </LinearLayout>
                        <ImageView
                            android:id="@+id/iv_offline_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_unselect"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                </LinearLayout>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/text_important_color_new"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_24"
                    android:layout_marginBottom="@dimen/dp_16"
                    android:text="@string/eyevue_feedback_type_three"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_btn_main"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_20">
                    <RelativeLayout
                        android:id="@+id/rl_version_layout"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/set_me_function_text_size"
                            android:textColor="@color/color_main_text"
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/ad_icon_height"
                            android:text="@string/string_system_update"
                            android:drawablePadding="@dimen/dp_10"
                            android:paddingStart="@dimen/set_me_function_padding_left"
                            android:paddingEnd="@dimen/set_me_function_padding_right"/>
                        <View
                            android:id="@+id/view_point"
                            android:background="@drawable/bg_radius_red_999"
                            android:visibility="gone"
                            android:layout_width="@dimen/dp_6"
                            android:layout_height="@dimen/dp_6"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/dp_8"
                            android:layout_toStartOf="@+id/tv_version"/>
                        <TextView
                            android:textSize="@dimen/sp_14"
                            android:textColor="@color/color_audio"
                            android:gravity="center"
                            android:id="@+id/tv_version"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/ad_icon_height"
                            android:layout_marginEnd="@dimen/dp_20"
                            android:layout_alignParentEnd="true"/>
                        <View
                            android:background="@color/color_line"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_alignParentBottom="true"
                            android:layout_marginHorizontal="@dimen/dp_20"/>
                    </RelativeLayout>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/color_main_text"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_device_info"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ad_icon_height"
                        android:text="@string/eyevue_device_info"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_disconnect_state"
                android:background="@color/black_60"
                android:focusable="true"
                android:visibility="gone"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </FrameLayout>
    </ScrollView>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/red_prominence"
        android:gravity="center"
        android:id="@+id/btn_unpair"
        android:background="@drawable/bg_radius_red"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_16"
        android:text="@string/string_unpair_device"
        android:layout_marginStart="@dimen/dp_45"
        android:layout_marginEnd="@dimen/dp_45"
        android:paddingVertical="@dimen/dp_17"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
