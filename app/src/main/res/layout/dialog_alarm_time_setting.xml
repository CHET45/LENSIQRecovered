<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/bg_radius_top_main_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:background="@drawable/bg_radius_282c2f"
        android:layout_width="@dimen/dp_34"
        android:layout_height="@dimen/dp_4"
        android:layout_marginTop="@dimen/dp_12"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_24"
        android:text="@string/string_time"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_30"
        android:layout_marginBottom="@dimen/dp_10"
        android:layout_marginHorizontal="@dimen/dp_16">
        <ImageView
            android:background="@drawable/bg_time_dialg_item"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_42"
            android:layout_centerInParent="true"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:weightSum="3"
            android:minHeight="@dimen/dp_200">
            <com.eyevue.common.widget.recyclerwheelpicker.RecyclerWheelPicker
                android:id="@+id/list0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <com.eyevue.common.widget.recyclerwheelpicker.RecyclerWheelPicker
                android:id="@+id/list1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:gravity="bottom|center_horizontal"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:id="@+id/dialog_clear_text_bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_60"
        android:layout_marginBottom="@dimen/dp_10"
        android:layout_marginHorizontal="@dimen/dp_16">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/dialog_clear_text_left_tv"
            android:padding="12dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/cancel"
            android:layout_weight="1"/>
        <View
            android:id="@+id/dialog_clear_text_vertical_divide"
            android:background="@color/dialog_line"
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="@dimen/dp_10"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/base_purple"
            android:gravity="center"
            android:id="@+id/dialog_clear_text_right_tv"
            android:padding="12dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="@string/confirm"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
