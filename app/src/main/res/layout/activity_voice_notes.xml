<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_44">
        <ImageView
            android:id="@+id/fr_back"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginHorizontal="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/color_main_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/trans_voice_notes_tip"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/dp_10"
        android:layout_above="@+id/iv_record"
        android:layout_below="@+id/rl_title"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_view"
        android:paddingBottom="@dimen/dp_100"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/img_voice_note"
            android:background="?attr/voiceEmptyIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/sp_15"
            android:textColor="@color/gray_999999"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:padding="@dimen/dp_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:text="@string/voice_note_view_tip"
            android:layout_marginHorizontal="@dimen/dp_35"/>
    </LinearLayout>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/iv_record"
        android:background="@drawable/bg_btn_main_base_purple"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_44"
        android:layout_marginBottom="@dimen/dp_20"
        android:minWidth="@dimen/dp_168"
        android:layout_alignParentBottom="true"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:paddingHorizontal="@dimen/dp_10">
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/btn_phone_voice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recording"
            android:drawableStart="@drawable/ic_trans_voice_black"/>
    </RelativeLayout>
</RelativeLayout>
