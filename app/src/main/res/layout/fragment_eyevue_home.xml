<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/cl_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:id="@+id/rl_title_layout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:paddingHorizontal="@dimen/dp_20"
            android:paddingVertical="@dimen/dp_6"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_device_name"
                android:background="@drawable/bg_round_161a1b"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_46"
                android:paddingEnd="@dimen/dp_10">
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/color_main_text"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tv_device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:maxWidth="@dimen/dp_150"
                    android:text="@string/app_name"
                    android:maxLines="1"
                    android:layout_marginStart="@dimen/dp_18"
                    android:layout_marginEnd="@dimen/dp_3"/>
                <ImageView
                    android:background="@drawable/ic_add_new_device_black"
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:layout_marginEnd="@dimen/dp_9"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/btn_guide"
                android:background="@drawable/ic_main_guide"
                android:visibility="gone"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dp_35"
                android:layout_alignParentEnd="true"/>
            <ImageView
                android:id="@+id/btn_device_list"
                android:background="@drawable/ic_device_list"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
            <ImageView
                android:id="@+id/btn_device_setting"
                android:background="@drawable/ic_device_setting"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dp_12"
                android:layout_toStartOf="@+id/btn_device_list"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/ll_connect_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_15"
            android:layout_marginHorizontal="@dimen/dp_20"
            app:layout_constraintTop_toBottomOf="@+id/rl_title_layout">
            <ImageView
                android:id="@+id/iv_red_point"
                android:background="@drawable/bg_radius_red_999"
                android:visibility="gone"
                android:layout_width="@dimen/dp_4"
                android:layout_height="@dimen/dp_4"
                android:layout_marginEnd="@dimen/dp_5"/>
            <ImageView
                android:id="@+id/iv_green_point"
                android:background="@drawable/bg_radius_green_999"
                android:visibility="gone"
                android:layout_width="@dimen/dp_4"
                android:layout_height="@dimen/dp_4"
                android:layout_marginEnd="@dimen/dp_5"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/color_main_text"
                android:id="@+id/tv_connect_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/eyevue_status_connected"
                android:layout_marginStart="@dimen/dp_2"/>
            <com.eyevue.common.widget.BatteryView
                android:id="@+id/battery"
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_12"
                android:layout_marginStart="@dimen/dp_24"
                android:layout_marginEnd="@dimen/dp_4"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/color_main_text"
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"/>
            <ImageView
                android:id="@+id/iv_charging"
                android:background="@drawable/ic_charging"
                android:visibility="gone"
                android:layout_width="@dimen/dp_18"
                android:layout_height="@dimen/dp_18"
                android:layout_marginStart="@dimen/dp_8"
                android:layout_marginEnd="@dimen/dp_4"/>
            <LinearLayout
                android:gravity="end"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/dp_20">
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/btn_connect_bt"
                    android:background="@drawable/bg_round_161a1b"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/string_click_connect"
                    android:drawableStart="@drawable/icon_bt"
                    android:paddingStart="@dimen/dp_10"
                    android:paddingEnd="@dimen/dp_20"
                    android:paddingVertical="@dimen/dp_4"/>
            </LinearLayout>
        </LinearLayout>
        <androidx.core.widget.NestedScrollView
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ll_connect_state">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:paddingBottom="@dimen/dp_50"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_9">
                <com.eyevue.common.widget.BvImageView
                    android:id="@+id/iv_device_img"
                    android:layout_width="@dimen/dp_273"
                    android:layout_height="@dimen/dp_273"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/btn_reconnect"
                    android:background="@drawable/bg_btn_main_base_purple999"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_20"
                    android:paddingHorizontal="@dimen/dp_30"
                    android:paddingVertical="@dimen/dp_8"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_device_img"
                    app:layout_constraintEnd_toEndOf="@+id/iv_device_img"
                    app:layout_constraintStart_toStartOf="@+id/iv_device_img">
                    <ImageView
                        android:id="@+id/iv_reconnect_anim"
                        android:visibility="gone"
                        android:layout_width="@dimen/dp_24"
                        android:layout_height="@dimen/dp_24"
                        android:layout_marginEnd="@dimen/dp_8"/>
                    <TextView
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="@dimen/dp_24"
                        android:minHeight="@dimen/dp_24"
                        android:text="@string/eyevue_connect_glasses"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/ll_camera"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_84"
                    android:layout_marginTop="@dimen/dp_18"
                    android:layout_marginHorizontal="@dimen/dp_20"
                    app:layout_constraintTop_toBottomOf="@+id/iv_device_img">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:id="@+id/btn_take_photo"
                        android:background="@drawable/bg_btn_main_function"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <ImageView
                            android:background="@drawable/icon_main_camera"
                            android:layout_width="@dimen/dp_42"
                            android:layout_height="@dimen/dp_42"/>
                        <TextView
                            android:textSize="@dimen/sp_11"
                            android:textColor="@color/white_70"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_main_take_photo"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:id="@+id/btn_record_video"
                        android:background="@drawable/bg_btn_main_function"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/dp_10">
                        <ImageView
                            android:background="@drawable/icon_main_video"
                            android:layout_width="@dimen/dp_42"
                            android:layout_height="@dimen/dp_42"/>
                        <LinearLayout
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:id="@+id/iv_recording_video"
                                android:background="@drawable/icon_recording"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_14"
                                android:layout_height="@dimen/dp_14"
                                android:layout_marginEnd="@dimen/dp_8"/>
                            <TextView
                                android:textSize="@dimen/sp_11"
                                android:textColor="@color/white_70"
                                android:id="@+id/tv_record_video"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_take_video"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="vertical"
                        android:id="@+id/btn_record_audio"
                        android:background="@drawable/bg_btn_main_function"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">
                        <ImageView
                            android:background="@drawable/icon_main_audio"
                            android:layout_width="@dimen/dp_42"
                            android:layout_height="@dimen/dp_42"/>
                        <LinearLayout
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:id="@+id/iv_recording_audio"
                                android:background="@drawable/icon_recording"
                                android:visibility="gone"
                                android:layout_width="@dimen/dp_14"
                                android:layout_height="@dimen/dp_14"
                                android:layout_marginEnd="@dimen/dp_8"/>
                            <TextView
                                android:textSize="@dimen/sp_11"
                                android:textColor="@color/white_70"
                                android:id="@+id/tv_record_audio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_record"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/ll_sound_live"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:layout_marginHorizontal="@dimen/dp_15"
                    app:layout_constraintTop_toBottomOf="@+id/ll_camera">
                    <LinearLayout
                        android:gravity="center"
                        android:id="@+id/btn_quick_volume"
                        android:background="@drawable/bg_btn_main_function"
                        android:visibility="gone"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dp_84"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/dp_5">
                        <ImageView
                            android:background="@drawable/icon_main_sound"
                            android:layout_width="@dimen/dp_42"
                            android:layout_height="@dimen/dp_42"/>
                        <TextView
                            android:textSize="@dimen/sp_11"
                            android:textColor="@color/white_70"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_main_sound"
                            android:layout_marginStart="@dimen/dp_20"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center"
                        android:id="@+id/btn_live"
                        android:background="@drawable/bg_btn_main_function"
                        android:visibility="gone"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dp_84"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="@dimen/dp_5">
                        <ImageView
                            android:background="@drawable/icon_main_live"
                            android:layout_width="@dimen/dp_42"
                            android:layout_height="@dimen/dp_42"/>
                        <TextView
                            android:textSize="@dimen/sp_11"
                            android:textColor="@color/white_70"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_live"
                            android:layout_marginStart="@dimen/dp_20"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/white"
                    android:id="@+id/tv_tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_32"
                    android:text="@string/string_tool"
                    android:layout_marginHorizontal="@dimen/dp_20"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/ll_sound_live"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rl_function_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/dp_8"
                    app:layout_constraintTop_toBottomOf="@+id/tv_tool"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/white"
                    android:id="@+id/tv_use_skill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:text="@string/string_use_skill"
                    android:layout_marginHorizontal="@dimen/dp_20"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rl_function_list"/>
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_use_skill"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/dp_20"
                    android:layout_marginHorizontal="@dimen/dp_20"
                    app:cardBackgroundColor="@color/color_dialog_bg"
                    app:cardCornerRadius="@dimen/dp_12"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="true"
                    app:cardUseCompatPadding="false"
                    app:layout_constraintTop_toBottomOf="@+id/tv_use_skill">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_133"
                        android:src="@drawable/img_use_skill"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_round_black_60_9999"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_18"
                    android:text="@string/string_know_glasses_base_operation"
                    android:layout_marginStart="@dimen/dp_16"
                    android:paddingHorizontal="@dimen/dp_22"
                    android:paddingVertical="@dimen/dp_12"
                    app:layout_constraintBottom_toBottomOf="@+id/btn_use_skill"
                    app:layout_constraintStart_toStartOf="@+id/btn_use_skill"/>
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_ai_skill"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="@dimen/dp_12"
                    android:layout_marginHorizontal="@dimen/dp_20"
                    app:cardBackgroundColor="@color/color_dialog_bg"
                    app:cardCornerRadius="@dimen/dp_12"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="true"
                    app:cardUseCompatPadding="false"
                    app:layout_constraintTop_toBottomOf="@+id/btn_use_skill">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_133"
                        android:src="@drawable/img_ai_skill"
                        android:scaleType="centerCrop"/>
                </androidx.cardview.widget.CardView>
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_round_black_60_9999"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_18"
                    android:text="@string/string_ai_use_skill"
                    android:layout_marginStart="@dimen/dp_16"
                    android:paddingHorizontal="@dimen/dp_22"
                    android:paddingVertical="@dimen/dp_12"
                    app:layout_constraintBottom_toBottomOf="@+id/btn_ai_skill"
                    app:layout_constraintStart_toStartOf="@+id/btn_ai_skill"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <RelativeLayout
        android:id="@+id/rl_adddevice_layout"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="@dimen/sp_24"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_20"
            android:text="@string/string_eyevue_glasses"
            android:layout_above="@+id/tv_tip2"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_6D6D6D"
            android:id="@+id/tv_tip2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_39"
            android:text="@string/string_eyevue_glasses_en"
            android:layout_above="@+id/rv_position"
            android:layout_centerHorizontal="true"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_position"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_3"
            android:layout_marginBottom="@dimen/dp_60"
            android:layout_above="@+id/btn_first_add_device"
            android:layout_centerHorizontal="true"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/btn_first_add_device"
            android:background="@drawable/bg_btn_main_base_purple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_50"
            android:minWidth="@dimen/dp_250"
            android:minHeight="@dimen/dp_50"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginHorizontal="@dimen/dp_62"
            android:paddingHorizontal="@dimen/dp_10">
            <ImageView
                android:background="@drawable/ic_add_new_device"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"/>
            <TextView
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/eyevue_add_add_device"
                android:paddingHorizontal="@dimen/dp_8"/>
        </LinearLayout>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
