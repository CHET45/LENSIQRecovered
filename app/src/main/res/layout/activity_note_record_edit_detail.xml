<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/gray_828282"
            android:gravity="center"
            android:id="@+id/tv_cancel"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/ai_voice_note_cancel"
            android:layout_alignParentStart="true"
            android:paddingHorizontal="@dimen/dp_16"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/base_purple"
            android:gravity="center"
            android:id="@+id/tv_save"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/ai_voice_note_string_save"
            android:layout_alignParentEnd="true"
            android:paddingHorizontal="@dimen/dp_16"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_44"
        android:layout_below="@+id/rl_title"
        android:layout_marginHorizontal="@dimen/dp_16">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:background="@drawable/shape_ai_voice_note_record_details_v1_bg"
                android:paddingTop="@dimen/dp_5"
                android:paddingBottom="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/dp_50">
                <EditText
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/ai_voice_note_list_title_color"
                    android:gravity="center_vertical"
                    android:id="@+id/edt_title"
                    android:background="@null"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="录音标题"
                    android:maxLength="50"
                    android:layout_marginStart="@dimen/dp_10"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/ai_voice_note_list_time_color"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:text="2024年9月14日 21:06"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/shape_ai_voice_note_record_details_v1_bg"
            android:padding="@dimen/dp_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12">
            <pl.droidsonroids.gif.GifImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/sv_wave"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_40"
                android:scaleType="fitXY"/>
            <com.watchfun.voicenotes.widget.CustomSeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_16"
                app:ballColor="@color/ai_voice_note_record_detail_ball_color"
                app:progressBgColor="@color/ai_voice_note_record_detail_progress_bg_color"
                app:progressColor="@color/ai_voice_note_record_detail_progress_color"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_24">
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/ai_voice_note_list_time_color"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_current_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/iv_before"
                    android:padding="@dimen/dp_10"
                    android:layout_width="@dimen/dp_42"
                    android:layout_height="@dimen/dp_42"
                    android:src="@drawable/ic_play_before"
                    android:layout_marginEnd="@dimen/dp_18"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_play"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/ic_play_start_v1"/>
                <ImageView
                    android:id="@+id/iv_after"
                    android:padding="@dimen/dp_10"
                    android:layout_width="@dimen/dp_42"
                    android:layout_height="@dimen/dp_42"
                    android:src="@drawable/ic_play_after"
                    android:layout_marginStart="@dimen/dp_18"/>
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/ai_voice_note_list_time_color"
                    android:gravity="end"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_current_total"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
        <ScrollView
            android:id="@+id/scroll_view"
            android:background="@drawable/shape_ai_voice_note_record_details_v1_bg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_12"
            android:fillViewport="true"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <EditText
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/ai_voice_note_list_title_color"
                    android:textColorHint="@color/ai_voice_note_list_title_color"
                    android:gravity="top"
                    android:id="@+id/edit_current_index"
                    android:background="@null"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/dp_16"
                    android:lineSpacingExtra="@dimen/dp_1"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</RelativeLayout>
