<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="58dp">
            <RelativeLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:id="@+id/iv_back"
                    android:background="@drawable/ic_search_back"
                    android:padding="@dimen/dp_35"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_27"
                    android:layout_height="@dimen/dp_27"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/dp_10"
                    android:layout_alignParentStart="true"/>
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/text_important_color"
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="@dimen/dp_145"
                    android:singleLine="true"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="@dimen/dp_4"
                    android:layout_marginEnd="@dimen/dp_4"/>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/text_important_color"
                android:gravity="center"
                android:id="@+id/btn_from_trans"
                android:background="@drawable/btn_ai_light_black"
                android:layout_width="@dimen/dp_90"
                android:layout_height="@dimen/dp_40"
                android:layout_centerInParent="true"
                android:drawableEnd="@drawable/ic_drop_down"
                android:paddingStart="@dimen/dp_5"
                android:paddingEnd="@dimen/dp_5"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_alignParentStart="true"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/ll_ai_model"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_58"
                android:layout_centerHorizontal="true"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_110">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:id="@+id/tv_ai_model"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <ImageView
                    android:id="@+id/img_arrow"
                    android:background="@drawable/ic_arrow_down"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    android:layout_marginStart="@dimen/dp_4"/>
            </LinearLayout>
            <TextView
                android:gravity="center"
                android:id="@+id/tv_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/voice_dialog_edit"
                android:layout_centerVertical="true"
                android:paddingStart="@dimen/dp_5"
                android:paddingEnd="@dimen/dp_5"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_root"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/dp_15">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_empty"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5">
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/empty_icon"
                    android:layout_width="@dimen/dp_76"
                    android:layout_height="@dimen/dp_76"
                    android:src="?attr/aiEmptyIcon"
                    android:layout_marginStart="@dimen/dp_20"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/chat_ai_empty_bg"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_84"
                    android:layout_marginTop="@dimen/dp_19">
                    <TextView
                        android:textSize="@dimen/sp_18"
                        android:textStyle="bold"
                        android:textColor="@color/text_important_color"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center"
                        android:id="@+id/tv_empty"
                        android:padding="@dimen/dp_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/chat_ai"
                        android:layout_marginStart="@dimen/dp_15"
                        android:layout_marginEnd="@dimen/dp_15"/>
                    <TextView
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/gray_828282"
                        android:ellipsize="end"
                        android:gravity="center_horizontal"
                        android:layout_gravity="center"
                        android:padding="@dimen/dp_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/chat_ai_tip"
                        android:maxLines="2"
                        android:layout_marginStart="@dimen/dp_15"
                        android:layout_marginEnd="@dimen/dp_15"/>
                </LinearLayout>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ai_rc"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:layout_weight="1"
                android:fadeScrollbars="false"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/bottom_view"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_70">
                <View
                    android:id="@+id/view_lines"
                    android:background="@color/main_tran_bg"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="0.8dp"/>
                <RelativeLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/bottom_view_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:id="@+id/ll_record_send"
                        android:background="@drawable/bg_round_1f2129_stroke_727272_radius_16"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_48"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/dp_20"
                        android:layout_toStartOf="@+id/ic_record_send"
                        android:layout_alignParentStart="true">
                        <ImageView
                            android:id="@+id/img_trans_voice"
                            android:background="@drawable/ic_trans_voice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textSize="@dimen/sp_14"
                            android:textStyle="bold"
                            android:textColor="?attr/imgbg"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:id="@+id/btn_record_send"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="@string/str_recorder_normal"
                            android:layout_marginStart="@dimen/dp_8"/>
                    </LinearLayout>
                    <ImageView
                        android:gravity="center"
                        android:id="@+id/ic_record_send"
                        android:background="@drawable/ic_keyboard"
                        android:layout_width="@dimen/dp_40"
                        android:layout_height="@dimen/dp_40"
                        android:layout_marginTop="@dimen/dp_20"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginEnd="@dimen/dp_20"
                        android:layout_alignParentEnd="true"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/ll_online_search"
                        android:background="@drawable/selector_bg_network"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/dp_48"
                        android:layout_marginTop="@dimen/dp_76"
                        android:layout_marginBottom="@dimen/dp_20"
                        android:paddingStart="@dimen/dp_6"
                        android:paddingEnd="@dimen/dp_6"
                        android:layout_marginStart="@dimen/dp_20">
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/selector_ic_network"/>
                        <TextView
                            android:textSize="@dimen/sp_12"
                            android:textColor="@drawable/selector_text_color_network"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/online_search"
                            android:layout_marginStart="@dimen/dp_4"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:id="@+id/ic_et_send"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dp_48"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/dp_20"
                        android:layout_toStartOf="@+id/ic_record_send"
                        android:layout_toEndOf="@+id/ll_record_send">
                        <EditText
                            android:textSize="@dimen/sp_14"
                            android:textColor="@color/text_important_color"
                            android:textColorHint="@color/gray_828282"
                            android:id="@+id/btn_et"
                            android:background="@drawable/bg_round_000000_radius_16"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:hint="@string/edit_hint_tip"
                            android:maxLength="300"
                            android:layout_weight="1"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/dp_15"/>
                        <LinearLayout
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:orientation="horizontal"
                            android:id="@+id/ic_send_view"
                            android:background="@drawable/bg_round_1f2129_radius_16"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/dp_20">
                            <TextView
                                android:gravity="center"
                                android:id="@+id/ic_send"
                                android:background="@drawable/ic_send"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:id="@+id/voice_view"
                android:background="@drawable/ai_trans_dialog_bg"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/dp_102"
                android:layout_alignParentBottom="true">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"
                    android:textColor="@color/text_important_color"
                    android:textColorHint="@color/gray_828282"
                    android:gravity="center"
                    android:id="@+id/txt_voice_value"
                    android:background="@null"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:hint="@string/str_recorder_dialog_tip"
                    android:layout_marginStart="@dimen/dp_30"
                    android:layout_marginEnd="@dimen/dp_30"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/img_voice"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_45"
                    android:layout_marginTop="@dimen/dp_8"
                    android:layout_marginStart="@dimen/dp_30"
                    android:layout_marginEnd="@dimen/dp_30"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:layout_marginBottom="@dimen/dp_10"
                    android:text="@string/click_to_stop"
                    android:layout_marginStart="@dimen/dp_30"
                    android:layout_marginEnd="@dimen/dp_30"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <com.watchfun.transcommon.widget.BottomEditView
        android:id="@+id/bottomEditView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
