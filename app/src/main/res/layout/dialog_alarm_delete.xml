<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/dp_142"
    android:layout_marginHorizontal="@dimen/dp_36">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/dialog_clear_text_main_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp_142">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/dialog_clear_text_container_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:minHeight="@dimen/dp_100"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/sp_18"
                android:textColor="@color/white"
                android:id="@+id/dialog_clear_text_title_tv"
                android:padding="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/string_delete_alarm"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="bottom|center_horizontal"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/dialog_clear_text_bottom_layout"
            android:layout_width="match_parent"
            android:layout_height="60dp">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/btn_cancel"
                android:padding="12dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/cancel"
                android:layout_weight="1"/>
            <View
                android:id="@+id/dialog_clear_text_vertical_divide"
                android:background="@color/white"
                android:layout_width="0.5dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="@dimen/dp_20"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/red_prominence"
                android:gravity="center"
                android:id="@+id/btn_delete"
                android:padding="12dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/string_delete"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
