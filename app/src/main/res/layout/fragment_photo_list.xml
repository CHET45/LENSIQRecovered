<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tv_retry"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="重试(仅测试可见)"/>
        <ImageView
            android:id="@+id/cancelButton"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/icon_album_cancel"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/color_main_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_main_album"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_16"/>
        <ImageView
            android:id="@+id/editButton"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/icon_album_edit"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/layout_import"
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_80"
        android:layout_marginTop="@dimen/dp_24"
        android:layout_below="@+id/rl_title"
        android:layout_marginHorizontal="@dimen/dp_16">
        <LinearLayout
            android:id="@+id/ll_album_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_20">
            <ImageView
                android:background="@drawable/img_album_top"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"/>
            <ImageView
                android:id="@+id/redpoint"
                android:background="@drawable/bg_radius_red_999"
                android:visibility="gone"
                android:layout_width="@dimen/dp_6"
                android:layout_height="@dimen/dp_6"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_main_text"
            android:id="@+id/tv_num"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/string_sync_photo"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_6"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_toStartOf="@+id/btn_import"
            android:layout_toEndOf="@+id/ll_album_top"/>
        <TextView
            android:textColor="@color/black"
            android:id="@+id/btn_import"
            android:background="@drawable/bg_btn_main_base_purple"
            android:paddingTop="@dimen/dp_3"
            android:paddingBottom="@dimen/dp_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_import"
            android:layout_centerVertical="true"
            android:paddingStart="@dimen/dp_15"
            android:paddingEnd="@dimen/dp_15"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/layout_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_below="@+id/layout_import"
        android:layout_marginHorizontal="@dimen/dp_20">
        <TextView
            android:textColor="@color/color_main_function"
            android:gravity="center"
            android:id="@+id/btn_type_all"
            android:background="@drawable/bg_btn_main_base_purple999"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/string_all"
            android:layout_weight="1"
            android:paddingVertical="@dimen/dp_9"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/btn_type_img"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/string_photo"
            android:layout_weight="1"
            android:paddingVertical="@dimen/dp_9"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/btn_type_video"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/string_video"
            android:layout_weight="1"
            android:paddingVertical="@dimen/dp_9"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/btn_type_audio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/string_audio"
            android:layout_weight="1"
            android:paddingVertical="@dimen/dp_9"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:paddingBottom="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_below="@+id/layout_type"
        android:overScrollMode="never"
        android:paddingStart="@dimen/dp_8"
        android:paddingEnd="@dimen/dp_8"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_115"
        android:layout_below="@+id/layout_import"
        android:layout_centerHorizontal="true">
        <ImageView
            android:background="@drawable/img_photo_empty"
            android:layout_width="@dimen/dp_202"
            android:layout_height="@dimen/dp_162"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_main_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_32"
            android:text="@string/string_album_empty"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_voice_notes_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/string_album_empty_tip"/>
    </LinearLayout>
</RelativeLayout>
