<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="horizontal"
    android:id="@+id/trans_img_layout"
    android:background="@drawable/bg_btn_main_function"
    android:visibility="visible"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_102"
    android:paddingHorizontal="@dimen/dp_5">
    <TextView
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="@string/string_takepicture_mode"
        android:layout_toStartOf="@+id/btn_horizontal_layout"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/btn_vertical_layout"
        android:layout_width="@dimen/dp_70"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/iv_vertical"
            android:background="@drawable/ic_vertical_un"
            android:layout_width="@dimen/dp_42"
            android:layout_height="@dimen/dp_42"/>
        <TextView
            android:textSize="@dimen/sp_11"
            android:textColor="@color/white_70"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/string_video_vertical"
            android:singleLine="true"
            android:paddingHorizontal="@dimen/dp_3"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/btn_horizontal_layout"
        android:layout_width="@dimen/dp_70"
        android:layout_height="match_parent"
        android:layout_toStartOf="@+id/btn_vertical_layout">
        <ImageView
            android:id="@+id/iv_horizontal"
            android:background="@drawable/ic_horizontal_un"
            android:layout_width="@dimen/dp_42"
            android:layout_height="@dimen/dp_42"/>
        <TextView
            android:textSize="@dimen/sp_11"
            android:textColor="@color/white_70"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/string_video_horizontal"
            android:singleLine="true"
            android:paddingHorizontal="@dimen/dp_3"/>
    </LinearLayout>
</RelativeLayout>
