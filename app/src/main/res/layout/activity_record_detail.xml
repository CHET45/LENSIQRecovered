<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">
        <ImageView
            android:id="@+id/fr_back"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/text_important_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/record_record_detail"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_44"
        android:layout_above="@+id/rl_edit"
        android:layout_below="@+id/rl_title"
        android:layout_marginHorizontal="@dimen/dp_16">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:id="@+id/edt_lang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentEnd="true"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/color_main_text"
                    android:id="@+id/edt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toLeftOf="@+id/edt_lang"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentStart="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="@color/tv_note"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_12"
                android:text="2024年9月14日 21:06"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_btn_main"
            android:padding="@dimen/dp_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_16">
            <pl.droidsonroids.gif.GifImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/sv_wave"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_40"
                android:scaleType="fitXY"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/tv_note"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_current_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/iv_play"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/ic_play_start"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/tv_note"
                    android:gravity="end"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_current_total"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
        <ScrollView
            android:id="@+id/scroll_view"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_16"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/color_main_text"
                    android:textColorHint="@color/tv_hint"
                    android:id="@+id/tv_current_index"
                    android:padding="@dimen/dp_20"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="@dimen/dp_1"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <RelativeLayout
        android:gravity="center"
        android:id="@+id/rl_edit"
        android:background="@drawable/bg_btn_main"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_44"
        android:layout_marginBottom="@dimen/dp_20"
        android:minWidth="@dimen/dp_120"
        android:layout_alignParentBottom="true"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="@dimen/dp_30"
        android:paddingHorizontal="@dimen/dp_20">
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/btn_phone_voice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voice_dialog_edit"/>
    </RelativeLayout>
</RelativeLayout>
