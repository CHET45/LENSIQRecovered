<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/bg_radius_top_main_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:background="@drawable/bg_radius_282c2f"
        android:layout_width="@dimen/dp_34"
        android:layout_height="@dimen/dp_4"
        android:layout_marginTop="@dimen/dp_12"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_copy"
        android:paddingTop="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_16"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_40"
        android:text="@string/string_copy_alarm"
        android:layout_marginHorizontal="@dimen/dp_16"/>
    <View
        android:background="@color/color_text_line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginHorizontal="@dimen/dp_16"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/color_red_e9"
        android:gravity="center"
        android:id="@+id/btn_delete"
        android:paddingTop="@dimen/dp_16"
        android:paddingBottom="@dimen/dp_16"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_26"
        android:text="@string/string_delete"
        android:layout_marginHorizontal="@dimen/dp_16"/>
</LinearLayout>
