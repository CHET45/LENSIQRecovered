<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center_horizontal"
    android:orientation="vertical"
    android:background="?attr/dialog_bg"
    android:layout_width="@dimen/dp_279"
    android:layout_height="@dimen/dp_195">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/dialog_clear_text_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/dialog_clear_text_container_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/text_16sp"
                android:textColor="@color/text_important_color"
                android:gravity="center_horizontal"
                android:id="@+id/dialog_clear_text_title_tv"
                android:padding="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/permission_tip1"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/dialog_clear_text_edit_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/gray_828282"
                    android:gravity="center_horizontal"
                    android:id="@+id/dialog_clear_text_tip_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_12"
                    android:text="@string/permission_tip2"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@+id/dialog_clear_text_horizontal_divide"
            android:background="@color/dialog_line"
            android:layout_width="match_parent"
            android:layout_height="0.2dp"/>
        <LinearLayout
            android:gravity="bottom|center_horizontal"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/dialog_text_bottom_layout"
            android:layout_width="match_parent"
            android:layout_height="60dp">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/gray_828282"
                android:gravity="center"
                android:id="@+id/dialog_refuse_text_left_tv"
                android:padding="12dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/permission_refuse"
                android:layout_weight="1"/>
            <View
                android:id="@+id/dialog_clear_text_vertical_divide"
                android:background="@color/dialog_line"
                android:layout_width="0.2dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_important_color"
                android:gravity="center"
                android:id="@+id/dialog_allow_text_right_tv"
                android:padding="12dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/permission_allow"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
