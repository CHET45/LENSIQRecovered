<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_8"
    android:layout_marginBottom="@dimen/dp_8"
    android:layout_marginStart="@dimen/dp_20"
    android:layout_marginEnd="@dimen/dp_20">
    <ImageView
        android:id="@+id/iv_select"
        android:visibility="visible"
        android:layout_width="@dimen/dp_20"
        android:layout_height="@dimen/dp_20"
        android:src="@drawable/ic_edit_unselect"
        android:layout_alignTop="@+id/item_one"
        android:layout_alignBottom="@+id/item_one"
        android:layout_marginEnd="@dimen/dp_10"/>
    <androidx.cardview.widget.CardView
        android:orientation="vertical"
        android:id="@+id/item_one"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_30"
        android:layout_alignParentEnd="true"
        app:cardBackgroundColor="@color/color_main_text"
        app:cardCornerRadius="@dimen/dp_16"
        app:cardElevation="0dp">
        <ImageView
            android:id="@+id/iv_img"
            android:layout_width="@dimen/dp_100"
            android:layout_height="@dimen/dp_100"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/item_two"
        android:background="@drawable/bg_radius_ai_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_below="@+id/item_one"
        android:layout_alignParentStart="true">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/img_load_point"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/text_loadding"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"/>
    </LinearLayout>
</RelativeLayout>
