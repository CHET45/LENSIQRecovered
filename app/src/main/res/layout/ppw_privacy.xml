<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/dp_40"
    android:layout_marginEnd="@dimen/dp_40">
    <TextView
        android:textSize="18sp"
        android:textColor="@color/text_important_color_new"
        android:gravity="center_horizontal"
        android:layout_gravity="center_horizontal"
        android:id="@+id/tv_privacy_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/eyevue_privacy_tip_one"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_30"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_10">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/text_important_color_new"
            android:layout_gravity="center_vertical"
            android:id="@+id/tv_privacy_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"/>
    </LinearLayout>
    <Button
        android:textSize="15sp"
        android:textStyle="normal"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_agree"
        android:background="@drawable/btn_agree_bg"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="@dimen/dp_30"
        android:text="@string/eyevue_privacy_btn_confirm"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="@dimen/dp_40"
        android:layout_marginEnd="@dimen/dp_40"/>
    <Button
        android:textSize="15sp"
        android:textStyle="normal"
        android:textColor="@color/text_important_color_new"
        android:gravity="center"
        android:id="@+id/btn_disagree"
        android:background="@drawable/btn_cancel_bg"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="@dimen/dp_15"
        android:layout_marginBottom="@dimen/dp_30"
        android:text="@string/cancel"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="@dimen/dp_40"
        android:layout_marginEnd="@dimen/dp_40"/>
</LinearLayout>
