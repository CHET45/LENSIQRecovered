<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_44">
        <ImageView
            android:id="@+id/iv_back"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_24"
            android:layout_alignParentStart="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/sp_18"
        android:textStyle="bold"
        android:textColor="@color/color_main_text"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_40"
        android:text="@string/eyevue_forget_password"
        android:layout_below="@+id/rl_title"
        android:layout_marginStart="@dimen/dp_24"/>
    <RelativeLayout
        android:id="@+id/email_layout"
        android:background="@drawable/bg_edit_auth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_40"
        android:layout_below="@+id/tv_title"
        android:layout_marginHorizontal="@dimen/dp_24">
        <com.eyevue.common.widget.MyEditText
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/color_main_text"
            android:textColorHint="@color/color_voice_notes_text"
            android:id="@+id/et_email"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:hint="@string/eyevue_hint_input_emial"
            android:paddingStart="@dimen/dp_20"
            android:layout_toStartOf="@+id/iv_clear_email"/>
        <ImageView
            android:id="@+id/iv_clear_email"
            android:background="@drawable/ic_close"
            android:visibility="invisible"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/verification_layout"
        android:background="@drawable/bg_edit_auth"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:layout_marginTop="@dimen/dp_24"
        android:layout_below="@+id/email_layout"
        android:layout_marginHorizontal="@dimen/dp_24">
        <TextView
            android:textSize="@dimen/text_12sp"
            android:textColor="@color/color_main_text"
            android:ellipsize="end"
            android:id="@+id/tv_send_code"
            android:paddingLeft="@dimen/dp_12"
            android:paddingTop="@dimen/dp_6"
            android:paddingRight="@dimen/dp_12"
            android:paddingBottom="@dimen/dp_6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/eyevue_send_verification_code"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
        <EditText
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/color_main_text"
            android:textColorHint="@color/color_voice_notes_text"
            android:ellipsize="end"
            android:id="@+id/et_verification"
            android:background="@null"
            android:padding="10dp"
            android:layout_width="450dp"
            android:layout_height="wrap_content"
            android:hint="@string/eyevue_input_verification_code"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:inputType="number"
            android:layout_toStartOf="@+id/tv_send_code"/>
    </RelativeLayout>
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/password_one_layout"
        android:background="@drawable/bg_edit_auth"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:layout_marginTop="@dimen/dp_24"
        android:layout_below="@+id/verification_layout"
        android:layout_marginHorizontal="@dimen/dp_24">
        <ImageView
            android:id="@+id/iv_hide_password"
            android:paddingLeft="@dimen/dp_12"
            android:paddingTop="@dimen/dp_6"
            android:paddingRight="@dimen/dp_12"
            android:paddingBottom="@dimen/dp_6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_alignParentEnd="true"/>
        <EditText
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/color_main_text"
            android:textColorHint="@color/color_voice_notes_text"
            android:id="@+id/et_password"
            android:background="@null"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/eyevue_input_password"
            android:layout_centerVertical="true"
            android:imeOptions="actionNext"
            android:textAlignment="viewStart"
            android:layout_toStartOf="@+id/iv_hide_password"
            android:layout_alignParentStart="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/password_layout"
        android:background="@drawable/bg_edit_auth"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:layout_marginTop="@dimen/dp_24"
        android:layout_below="@+id/password_one_layout"
        android:layout_marginHorizontal="@dimen/dp_24">
        <ImageView
            android:id="@+id/iv_confirm_hide_password"
            android:paddingLeft="@dimen/dp_12"
            android:paddingTop="@dimen/dp_6"
            android:paddingRight="@dimen/dp_12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_alignParentEnd="true"/>
        <EditText
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/color_main_text"
            android:textColorHint="@color/color_voice_notes_text"
            android:id="@+id/et_confirm_password"
            android:background="@null"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/eyevue_confirm_password"
            android:layout_centerVertical="true"
            android:imeOptions="actionNext"
            android:textAlignment="viewStart"
            android:layout_toStartOf="@+id/iv_confirm_hide_password"
            android:layout_alignParentStart="true"/>
    </RelativeLayout>
    <androidx.appcompat.widget.AppCompatButton
        android:enabled="false"
        android:textSize="@dimen/text_16sp"
        android:textColor="@color/color_voice_notes_text"
        android:id="@+id/btn_modify_password"
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:layout_marginTop="@dimen/dp_80"
        android:text="@string/eyevue_modify_password"
        android:layout_below="@+id/password_layout"
        android:textAllCaps="false"
        android:layout_marginHorizontal="@dimen/dp_24"
        style="?android:attr/borderlessButtonStyle"/>
</RelativeLayout>
