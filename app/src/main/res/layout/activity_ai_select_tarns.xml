<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48">
        <ImageView
            android:id="@+id/iv_back"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginHorizontal="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/text_important_color"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/dp_145"
            android:singleLine="true"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_4"
            android:layout_marginEnd="@dimen/dp_4"/>
    </RelativeLayout>
    <EditText
        android:textSize="@dimen/sp_14"
        android:textColor="@color/text_important_color"
        android:textColorHint="@color/gray_8B8B8B"
        android:id="@+id/search_edit"
        android:background="@drawable/bg_btn_main"
        android:padding="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_40"
        android:layout_marginTop="@dimen/dp_20"
        android:hint="@string/search_language"
        android:drawablePadding="10dp"
        android:inputType="text"
        android:drawableStart="@drawable/ic_search_language"
        android:drawableEnd="@drawable/ic_dialog_close"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/text_important_color"
        android:gravity="center"
        android:id="@+id/tv_num"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/select_trans_rc"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/dp_10"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:overScrollMode="never"
        android:layout_marginHorizontal="@dimen/dp_20"/>
</LinearLayout>
