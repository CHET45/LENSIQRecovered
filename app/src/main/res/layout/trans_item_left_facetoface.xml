<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_10"
    android:layout_marginBottom="@dimen/dp_15"
    android:layout_marginStart="@dimen/dp_20"
    android:layout_marginEnd="@dimen/dp_20">
    <ImageView
        android:id="@+id/iv_select"
        android:background="@drawable/ic_edit_unselect"
        android:visibility="gone"
        android:layout_width="@dimen/dp_20"
        android:layout_height="@dimen/dp_20"
        android:layout_centerVertical="true"/>
    <ImageView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/text_important_color"
        android:layout_gravity="end|center_vertical"
        android:id="@+id/img_phone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_left_ear"
        android:layout_toEndOf="@+id/iv_select"/>
    <ImageView
        android:id="@+id/img_polygon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_18"
        android:src="@drawable/ic_left_polygon"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_toEndOf="@+id/img_phone"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/item_one"
        android:background="@drawable/btn_ai_trans_write"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_10"
        android:layout_toEndOf="@+id/img_polygon">
        <RelativeLayout
            android:orientation="horizontal"
            android:padding="@dimen/dp_10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/white"
                android:id="@+id/phone_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ttttt"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <View
            android:id="@+id/view_line"
            android:background="@color/black"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_10"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/white"
            android:id="@+id/phone_trans_value"
            android:padding="@dimen/dp_10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ttttt"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/receive_item_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_20">
            <LinearLayout
                android:layout_gravity="start|center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="30dp">
                <ImageView
                    android:textColor="@color/white"
                    android:layout_gravity="center"
                    android:id="@+id/receive_img_voice_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_trans_playing_btn"
                    android:scaleType="centerInside"
                    android:paddingStart="@dimen/dp_6"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/receive_img_voice"
                    android:background="@drawable/ic_volume_ai_play"
                    android:paddingLeft="2dp"
                    android:paddingRight="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_10"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_important_color"
                android:gravity="end|center_vertical"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/translate_text"
                android:padding="10dp"
                android:paddingLeft="2dp"
                android:paddingRight="2dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:layout_marginTop="20dp"
                android:text="翻译"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
