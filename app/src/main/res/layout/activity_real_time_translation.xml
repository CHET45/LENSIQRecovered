<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_49"
        android:layout_marginTop="@dimen/dp_6">
        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/dp_28"
            android:layout_height="@dimen/dp_28"
            android:src="@drawable/ic_back_realtime"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_20"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/img_exchange"
            android:layout_toEndOf="@+id/iv_back">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/text_important_color"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/btn_from_trans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="2"
                android:drawablePadding="@dimen/dp_6"
                android:layout_centerVertical="true"
                android:drawableEnd="@drawable/ic_arrow_down"
                android:paddingStart="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/img_exchange"
            android:background="@drawable/ic_exchange_realtime"
            android:visibility="visible"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_10"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/img_exchange">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/text_important_color"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/btn_to_trans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="2"
                android:drawablePadding="@dimen/dp_6"
                android:drawableEnd="@drawable/ic_arrow_down"
                android:paddingEnd="@dimen/dp_10"
                android:layout_marginStart="@dimen/dp_20"/>
        </RelativeLayout>
    </RelativeLayout>
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/content_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/rl_bottom"
        android:layout_below="@+id/rl_title">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_source"
                    android:background="@color/transparent"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:fadeScrollbars="false"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                <TextView
                    android:textSize="@dimen/sp_15"
                    android:textColor="@color/gray_999999"
                    android:id="@+id/tv_say"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:layout_marginStart="@dimen/dp_20"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/layout_translated"
                android:background="@color/trans_machine_color"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_translated"
                    android:paddingTop="@dimen/dp_18"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/dp_10"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:layout_weight="1"
                    android:fadeScrollbars="false"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                <View
                    android:id="@+id/view_bottom"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_50"
                    android:layout_marginTop="@dimen/dp_25"/>
                <ImageView
                    android:layout_gravity="start|bottom"
                    android:id="@+id/receive_img_voice_btn"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleType="centerInside"/>
            </FrameLayout>
        </LinearLayout>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/img_voice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="@dimen/dp_28"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_100">
        <ImageView
            android:id="@+id/img_trans_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_200"
            android:layout_marginStart="@dimen/dp_40"
            android:layout_marginEnd="@dimen/dp_40"
            app:radius="10dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_30"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_30">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/text_important_color"
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:text="@string/trans_machine_view_tip"
                android:layout_marginStart="@dimen/dp_25"
                android:layout_marginEnd="@dimen/dp_25"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_bottom"
        android:background="@color/trans_machine_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <RelativeLayout
            android:id="@+id/rl_operator"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_20"
            android:paddingStart="@dimen/dp_40"
            android:paddingEnd="@dimen/dp_40">
            <ImageView
                android:id="@+id/iv_broadcast"
                android:layout_width="@dimen/dp_44"
                android:layout_height="@dimen/dp_44"
                android:src="@null"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/iv_start"
                android:layout_width="@dimen/dp_60"
                android:layout_height="@dimen/dp_60"
                android:src="@drawable/ic_start_recording"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/iv_clear_exit"
                android:layout_width="@dimen/dp_44"
                android:layout_height="@dimen/dp_44"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_10"
                android:src="@drawable/ic_trans_mask"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/btn_start_layout"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_70">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/btn_start"
                android:background="@drawable/btn_base_purple"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_56"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_20">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/imageViews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_trans_voice"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_recorder_normal"
                    android:layout_marginStart="@dimen/dp_12"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/voice_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dp_112">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/txt_voice_value"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:hint="@string/str_recorder_dialog_tip"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
            <ImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_40"
                android:layout_marginTop="@dimen/dp_5"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/click_to_stop"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
