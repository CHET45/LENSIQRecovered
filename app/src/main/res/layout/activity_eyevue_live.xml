<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>
    <RelativeLayout
        android:id="@+id/fl_video"
        android:background="@drawable/bg_rect_base_purple"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">
        <androidx.cardview.widget.CardView
            android:id="@+id/card_view"
            android:background="@color/color_1f"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/dp_2"
            app:cardBackgroundColor="@color/color_1f"
            app:cardCornerRadius="@dimen/dp_10"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="true">
            <org.videolan.libvlc.util.VLCVideoLayout
                android:id="@+id/player_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <View
                android:id="@+id/view_overlay"
                android:background="@color/color_1f"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </androidx.cardview.widget.CardView>
        <ImageView
            android:id="@+id/btn_rotate"
            android:background="@drawable/icon_live_rotation"
            android:layout_width="@dimen/dp_36"
            android:layout_height="@dimen/dp_36"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_20"/>
    </RelativeLayout>
    <TextView
        android:textColor="@color/white"
        android:id="@+id/tv_connect_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/string_wifi_connecting"
        app:layout_constraintBottom_toBottomOf="@+id/fl_video"
        app:layout_constraintEnd_toEndOf="@+id/fl_video"
        app:layout_constraintStart_toStartOf="@+id/fl_video"
        app:layout_constraintTop_toTopOf="@+id/fl_video"/>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/btn_reconnect"
        android:background="@drawable/btn_base_purple_999"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_120"
        android:paddingHorizontal="@dimen/dp_35"
        android:paddingVertical="@dimen/dp_6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fl_video">
        <ImageView
            android:background="@drawable/icon_live_reconnect"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_live_reconnect"
            android:layout_marginStart="@dimen/dp_8"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
