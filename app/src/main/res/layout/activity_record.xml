<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_44">
        <ImageView
            android:id="@+id/fr_back"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_alignParentStart="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true">
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/iv_record_status"
                android:background="@drawable/ic_record_mic_normal"
                android:layout_width="@dimen/dp_18"
                android:layout_height="@dimen/dp_18"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_voice_notes_text"
                android:gravity="center_vertical"
                android:id="@+id/tv_record_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:layout_marginStart="@dimen/dp_8"/>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginBottom="@dimen/dp_59"
        android:layout_above="@+id/fr_control"
        android:layout_below="@+id/rl_title"
        android:layout_marginHorizontal="@dimen/dp_20">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:id="@+id/edt_lang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentEnd="true"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:id="@+id/edt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toLeftOf="@+id/edt_lang"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentStart="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textColor="@color/tv_note"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:text="2024年9月14日 21:06"/>
        </LinearLayout>
        <FrameLayout
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_80"
            android:layout_marginTop="@dimen/dp_16">
            <pl.droidsonroids.gif.GifImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/sv_wave"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/dp_20"
                android:scaleType="fitXY"/>
        </FrameLayout>
        <ScrollView
            android:id="@+id/scroll_view"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/text_important_color"
                    android:textColorHint="@color/gray_828282"
                    android:id="@+id/tv_current_index"
                    android:padding="@dimen/dp_16"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/speak_listen"
                    android:lineSpacingExtra="@dimen/dp_1"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/fr_control"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_46"
        android:layout_marginBottom="@dimen/dp_36"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <TextView
            android:textColor="@color/text_important_color"
            android:gravity="center"
            android:id="@+id/iv_record"
            android:background="@drawable/btn_base_left"
            android:layout_width="@dimen/dp_120"
            android:layout_height="@dimen/dp_44"
            android:layout_marginBottom="@dimen/dp_5"
            android:text="@string/text_start"/>
        <TextView
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/iv_finish"
            android:background="@drawable/btn_base_purple"
            android:layout_width="@dimen/dp_120"
            android:layout_height="@dimen/dp_44"
            android:text="@string/stop_record_voice"
            android:layout_marginStart="@dimen/dp_32"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_tip_network"
        android:background="@drawable/shape_base_bg"
        android:paddingLeft="@dimen/dp_15"
        android:paddingTop="@dimen/dp_5"
        android:paddingRight="@dimen/dp_15"
        android:paddingBottom="@dimen/dp_5"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_15"
        android:text="@string/string_voice_notes_neterror"
        android:layout_above="@+id/fr_control"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
