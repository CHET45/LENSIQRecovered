<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_home_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_add_anim"
        android:background="@drawable/anim_add_device"
        android:layout_width="@dimen/dp_240"
        android:layout_height="@dimen/dp_240"
        android:layout_centerInParent="true"/>
    <TextView
        android:textColor="@color/white"
        android:id="@+id/btn_first_add_device"
        android:background="@drawable/bg_btn_main"
        android:paddingTop="@dimen/dp_11"
        android:paddingBottom="@dimen/dp_11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_24"
        android:text="@string/eyevue_add_add_device"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:paddingStart="@dimen/dp_90"
        android:paddingEnd="@dimen/dp_90"/>
</RelativeLayout>
