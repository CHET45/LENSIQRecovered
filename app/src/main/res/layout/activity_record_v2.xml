<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">
        <FrameLayout
            android:id="@+id/fr_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:paddingStart="@dimen/dp_17"
            android:paddingEnd="@dimen/dp_17">
            <ImageView
                android:layout_gravity="center"
                android:background="@drawable/ic_search_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </FrameLayout>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/ai_voice_note_list_title_color"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/rl_title"
        android:layout_marginHorizontal="@dimen/dp_20">
        <LinearLayout
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_20"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:id="@+id/edt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentStart="true"/>
            </RelativeLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_17">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_voice_note_date"/>
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="#828282"
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024年9月14日 21:06"
                    android:layout_marginStart="@dimen/dp_9"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:background="@color/voice_note_connect_add_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_1"
            android:layout_marginTop="@dimen/dp_12"/>
        <FrameLayout
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_215"
            android:layout_marginTop="@dimen/dp_72">
            <pl.droidsonroids.gif.GifImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/sv_wave"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_weight="1">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/color_727272"
                android:id="@+id/tv_start_tip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:text="@string/ai_voice_note_start_tip"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_record"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <LinearLayout
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/white_F0F1F5"
                    android:textColorHint="#bdbdbd"
                    android:id="@+id/tv_current_index"
                    android:padding="@dimen/dp_16"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ai_voice_note_record_record_start_tip"
                    android:lineSpacingExtra="@dimen/dp_1"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/sp_40"
            android:textColor="@color/ai_voice_note_list_title_color"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:id="@+id/tv_record_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_32"
            android:text="00:00:00"
            android:layout_marginStart="@dimen/dp_8"/>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:id="@+id/fr_control"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_97"
            android:layout_marginStart="@dimen/dp_44"
            android:layout_marginEnd="@dimen/dp_44">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_record"
                    android:layout_width="@dimen/dp_72"
                    android:layout_height="@dimen/dp_72"
                    android:src="@drawable/ic_record_start_v1"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/ai_voice_note_818588"
                    android:id="@+id/tv_record_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:text="@string/ai_voice_note_tip_start_record"/>
            </LinearLayout>
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_finish"
                    android:layout_width="@dimen/dp_72"
                    android:layout_height="@dimen/dp_72"
                    android:src="@drawable/btn_record_finish_v1"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/ai_voice_note_818588"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:text="@string/ai_voice_note_string_save"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/ll_bottom"
        android:background="@drawable/bg_round_191a1d_top_radius_40"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_107"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/dp_20">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_22"
                android:layout_marginStart="@dimen/dp_27">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_record_status"
                    android:background="@drawable/ic_record_mic_normal"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_18"
                    android:layout_height="@dimen/dp_18"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="#828282"
                android:ellipsize="end"
                android:id="@+id/edt_lang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_7"
                android:maxLines="2"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dp_27"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_alignParentEnd="true"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_tip_network"
        android:background="@drawable/shape_base_bg"
        android:paddingLeft="@dimen/dp_15"
        android:paddingTop="@dimen/dp_5"
        android:paddingRight="@dimen/dp_15"
        android:paddingBottom="@dimen/dp_5"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_15"
        android:text="@string/string_voice_notes_neterror"
        android:layout_above="@+id/ll_bottom"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
