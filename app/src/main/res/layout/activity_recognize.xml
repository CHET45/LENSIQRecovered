<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textColor="#333333"
        android:gravity="center"
        android:id="@+id/tv_result"
        android:background="#f1f1f1"
        android:padding="15dp"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <Button
        android:id="@+id/button_start"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="start session"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_result"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_record"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toBottomOf="@+id/button_start">
        <Button
            android:id="@+id/button_start_record"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="start rec"
            android:layout_weight="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button_start"/>
        <Button
            android:id="@+id/button_stop_record"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="stop rec"
            android:layout_weight="1"
            android:layout_marginStart="15dp"
            app:layout_constraintLeft_toLeftOf="parent"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_lan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toBottomOf="@+id/ll_record">
        <Button
            android:id="@+id/button_choose_ko"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="choose ko"
            android:layout_weight="1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button_start"/>
        <Button
            android:id="@+id/button_choose_ja"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="choose ja"
            android:layout_weight="1"
            android:layout_marginStart="15dp"
            app:layout_constraintLeft_toLeftOf="parent"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/ll_play"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_lan">
        <Button
            android:id="@+id/button_play_one"
            android:visibility="visible"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="play one"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/button_play_two"
            android:visibility="visible"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="play two"
            android:layout_weight="1"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_language"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_play"/>
    <Button
        android:id="@+id/button_download_basic"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="download offline basic"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_read"/>
    <Button
        android:id="@+id/button_download_language_en"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="download offline lan en"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_download_basic"/>
    <Button
        android:id="@+id/button_download_pause"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="download offline pause resume"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_download_language_en"/>
</androidx.constraintlayout.widget.ConstraintLayout>
