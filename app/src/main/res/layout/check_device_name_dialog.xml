<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_175"
    android:layout_marginStart="@dimen/dp_40"
    android:layout_marginEnd="@dimen/dp_40">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/dialog_clear_text_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/dialog_clear_text_container_layout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/dialog_clear_text_edit_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/white"
                    android:gravity="center_horizontal"
                    android:id="@+id/dialog_tip_tv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_12"
                    android:text="@string/device_name_dialog_tip"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:id="@+id/dialog_clear_text_horizontal_divide"
            android:background="@color/black"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"/>
        <LinearLayout
            android:gravity="bottom|center_horizontal"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/dialog_clear_text_bottom_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/gray_828282"
                android:gravity="center"
                android:id="@+id/dialog_left_tv"
                android:padding="16dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/device_name_dialog_left_tip"
                android:layout_weight="1"/>
            <View
                android:id="@+id/dialog_clear_text_vertical_divide"
                android:background="@color/black"
                android:layout_width="0.5dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/base_purple"
                android:gravity="center"
                android:id="@+id/dialog_right_tv"
                android:padding="16dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/device_name_dialog_right_tip"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
