<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp">
    <RelativeLayout
        android:id="@+id/title_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_44">
        <TextView
            android:textSize="@dimen/sp_22"
            android:textStyle="bold"
            android:textColor="@color/black_333"
            android:id="@+id/tv_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/eyevue_main_mine_text"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_16"/>
        <ImageView
            android:id="@+id/btn_alarm"
            android:padding="@dimen/dp_10"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_alarm"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <androidx.core.widget.NestedScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_marginBottom="10dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/login_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:id="@+id/user_icon_view"
                    android:layout_width="@dimen/dp_75"
                    android:layout_height="@dimen/dp_75"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:id="@+id/user_icon"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>
                </FrameLayout>
                <TextView
                    android:textSize="@dimen/sp_22"
                    android:textStyle="bold"
                    android:textColor="@color/color_main_text"
                    android:id="@+id/login_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_12"
                    android:text="@string/tourist"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/user_icon_view"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_32"
                android:layout_marginHorizontal="@dimen/dp_16">
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_btn_main"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/bind_device_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/set_text_size"
                            android:textColor="@color/tv_me_function"
                            android:gravity="center_vertical"
                            android:id="@+id/bind_device"
                            android:layout_width="@dimen/dp_180"
                            android:layout_height="@dimen/ad_icon_height"
                            android:text="@string/eyevue_binding_device"
                            android:drawablePadding="@dimen/dp_10"
                            android:drawableStart="@drawable/ic_bind_device"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/set_button_text_padding_right"
                            android:layout_alignParentStart="true"/>
                        <TextView
                            android:textSize="@dimen/tablayout_text_size"
                            android:textColor="@color/white_8F8F8F"
                            android:id="@+id/bind_device_tip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/dp_10"
                            android:layout_centerVertical="true"
                            android:drawableEnd="@drawable/ic_bv_more"
                            android:paddingStart="@dimen/set_button_text_padding_left"
                            android:paddingEnd="@dimen/set_button_text_padding_right"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/color_text_line"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="@dimen/dp_20"
                        android:layout_marginEnd="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/tv_me_function"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_user_info"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/me_function_height"
                        android:text="@string/account_and_security"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_user_info"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                    <View
                        android:background="@color/color_text_line"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/tv_me_function"
                        android:gravity="center_vertical"
                        android:id="@+id/mine_beginner_guide"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/me_function_height"
                        android:text="@string/beginner_guide"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_beginner_guide"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                    <View
                        android:background="@color/color_text_line"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/tv_me_function"
                        android:gravity="center_vertical"
                        android:id="@+id/mine_permission"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/me_function_height"
                        android:text="@string/background_permission_settings"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_permission_settings"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_btn_main"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_12">
                    <RelativeLayout
                        android:orientation="horizontal"
                        android:id="@+id/update_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="@dimen/set_text_size"
                            android:textColor="@color/tv_me_function"
                            android:gravity="center_vertical"
                            android:id="@+id/language_text"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/ad_icon_height"
                            android:text="@string/text_select_language"
                            android:drawablePadding="@dimen/dp_10"
                            android:drawableStart="@drawable/ic_select_language"
                            android:paddingStart="@dimen/dp_15"
                            android:paddingEnd="@dimen/set_button_text_padding_right"
                            android:layout_alignParentStart="true"/>
                        <TextView
                            android:textSize="@dimen/tablayout_text_size"
                            android:textColor="@color/white_8F8F8F"
                            android:ellipsize="end"
                            android:gravity="end|center_vertical"
                            android:id="@+id/select_language"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:drawablePadding="@dimen/dp_10"
                            android:layout_centerVertical="true"
                            android:drawableEnd="@drawable/ic_bv_more"
                            android:paddingStart="@dimen/set_button_text_padding_left"
                            android:paddingEnd="@dimen/dp_20"
                            android:layout_marginStart="@dimen/dp_5"
                            android:layout_toEndOf="@+id/language_text"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <View
                        android:background="@color/dialog_line"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="@dimen/dp_20"
                        android:layout_marginEnd="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/tv_me_function"
                        android:gravity="center_vertical"
                        android:id="@+id/user_feedback"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/me_function_height"
                        android:text="@string/me_feedback"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_help_feedback"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                    <View
                        android:background="@color/color_text_line"
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/tv_me_function"
                        android:gravity="center_vertical"
                        android:id="@+id/mine_about"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/me_function_height"
                        android:text="@string/eyevue_mine_about"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_about"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                </LinearLayout>
                <RelativeLayout
                    android:orientation="horizontal"
                    android:id="@+id/update_app"
                    android:background="@drawable/bg_btn_main"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_16">
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/tv_me_function"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/me_function_height"
                        android:text="@string/eyevue_text_update_app"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_update_app"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"/>
                    <TextView
                        android:textSize="@dimen/set_me_function_text_size"
                        android:textColor="@color/textColor"
                        android:id="@+id/update_app_more"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawablePadding="@dimen/dp_10"
                        android:layout_centerVertical="true"
                        android:paddingStart="@dimen/set_me_function_padding_left"
                        android:paddingEnd="@dimen/set_me_function_padding_right"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <View
                        android:background="@color/dialog_line"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/dp_20"
                        android:layout_marginEnd="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/text_16sp"
                        android:textColor="@color/text_important_color_new"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_user_agreement"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ad_icon_height"
                        android:layout_marginTop="@dimen/dp_12"
                        android:text="@string/eyevue_user_agreement"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_user_agreement"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/dp_15"
                        android:paddingEnd="@dimen/set_button_text_padding_right"/>
                    <View
                        android:background="@color/dialog_line"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/dp_20"
                        android:layout_marginEnd="@dimen/dp_20"/>
                    <TextView
                        android:textSize="@dimen/text_16sp"
                        android:textColor="@color/text_important_color_new"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_privacy_policy"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/ad_icon_height"
                        android:layout_marginTop="@dimen/dp_12"
                        android:text="@string/eyevue_privacy_agreement"
                        android:drawablePadding="@dimen/dp_10"
                        android:drawableStart="@drawable/ic_privacy_policy"
                        android:drawableEnd="@drawable/ic_bv_more"
                        android:paddingStart="@dimen/dp_15"
                        android:paddingEnd="@dimen/set_button_text_padding_right"
                        app:layout_constraintTop_toBottomOf="@+id/view_line"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
