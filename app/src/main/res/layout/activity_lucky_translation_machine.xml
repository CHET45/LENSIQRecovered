<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="horizontal"
        android:id="@+id/title_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48">
        <ImageView
            android:id="@+id/iv_back_btn"
            android:background="@drawable/ic_search_back"
            android:padding="@dimen/dp_35"
            android:visibility="visible"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_alignParentStart="true"/>
        <Chronometer
            android:textSize="@dimen/sp_16"
            android:id="@+id/chronometer"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/iv_back_btn"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/img_exchange"
            android:background="@drawable/ic_exchange"
            android:visibility="visible"
            android:layout_width="32dp"
            android:layout_height="@dimen/dp_20"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_8"
            android:layout_marginEnd="@dimen/dp_8"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_important_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/btn_from_trans"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_32"
            android:lines="2"
            android:layout_centerVertical="true"
            android:drawableEnd="@drawable/ic_black_down_arrow"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="@dimen/dp_20"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_toStartOf="@+id/img_exchange"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_important_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/btn_to_trans"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_32"
            android:lines="2"
            android:layout_centerVertical="true"
            android:drawableEnd="@drawable/ic_black_down_arrow"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_toEndOf="@+id/img_exchange"/>
        <ImageView
            android:gravity="center"
            android:id="@+id/btn_flip_rv_source"
            android:padding="@dimen/dp_10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/iv_flip_rv_source"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_root"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/rl_bottom"
        android:layout_below="@+id/title_layout">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_source"
                android:paddingTop="@dimen/dp_12"
                android:paddingBottom="@dimen/dp_12"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/dp_12"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:fadeScrollbars="false"
                android:overScrollMode="never"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_20"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/layout_translated"
            android:background="#fff8ea"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_translated"
                android:paddingTop="@dimen/dp_12"
                android:paddingBottom="@dimen/dp_12"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/dp_10"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:layout_weight="1"
                android:fadeScrollbars="false"
                android:overScrollMode="never"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_20"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        </FrameLayout>
    </LinearLayout>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/img_voice"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dp_40"
        android:layout_alignTop="@+id/content_root"
        android:layout_alignBottom="@+id/content_root"
        android:layout_centerInParent="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_100"
        android:layout_below="@+id/title_layout">
        <ImageView
            android:id="@+id/img_trans_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_200"
            android:layout_marginStart="@dimen/dp_40"
            android:layout_marginEnd="@dimen/dp_40"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_30"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_30">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/text_important_color"
                android:id="@+id/tv_button_hint"
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:text="@string/trans_machine_view_tip"
                android:layout_marginStart="@dimen/dp_25"
                android:layout_marginEnd="@dimen/dp_25"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_bottom"
        android:background="@drawable/lucky_trans_machine_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <ImageView
            android:id="@+id/ic_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_34"
            android:src="@drawable/ic_translation_machine_record"
            android:layout_marginEnd="@dimen/dp_30"
            android:layout_toStartOf="@+id/btn_start_layout"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/btn_start_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_20"
            android:layout_centerHorizontal="true">
            <LinearLayout
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/btn_start"
                android:background="@drawable/btn_machine_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_20">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/imageViews"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_trans_voice"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_important_color"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:text="@string/str_recorder_normal_click"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/voice_view"
            android:background="@drawable/ai_trans_dialog_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                android:textColor="@color/text_important_color"
                android:textColorHint="@color/text_important_color"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/txt_voice_value"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_5"
                android:hint="@string/str_recorder_dialog_tip"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/text_important_color"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lift_to_stop"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
        </LinearLayout>
        <com.watchfun.transcommon.widget.BottomEditView
            android:id="@+id/bottomEditView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <ImageView
            android:id="@+id/iv_finish"
            android:background="@drawable/ic_record_finish"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_50"
            android:layout_centerHorizontal="true"/>
        <ImageView
            android:id="@+id/iv_control_record"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/dp_30"
            android:src="@drawable/ic_volume_pause"
            android:layout_toLeftOf="@+id/iv_finish"
            android:layout_alignTop="@+id/iv_finish"
            android:layout_alignBottom="@+id/iv_finish"/>
    </RelativeLayout>
</RelativeLayout>
