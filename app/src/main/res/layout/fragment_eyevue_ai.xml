<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        app:layout_constraintTop_toTopOf="parent">
        <RelativeLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:id="@+id/btn_test_pcm"
                android:layout_width="@dimen/dp_70"
                android:layout_height="@dimen/dp_40"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_toStartOf="@+id/tv_title"/>
            <TextView
                android:textSize="@dimen/sp_18"
                android:textColor="@color/color_main_text"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/dp_145"
                android:text="@string/ai_mode_tip"
                android:singleLine="true"
                android:layout_centerInParent="true"
                android:layout_marginStart="@dimen/dp_4"
                android:layout_marginEnd="@dimen/dp_4"/>
            <ImageView
                android:id="@+id/btn_edit"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:src="@drawable/icon_album_edit"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_alignParentEnd="true"/>
            <ImageView
                android:id="@+id/btn_duplex"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:src="@drawable/icon_ai_duplex_un"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/dp_12"
                android:layout_toStartOf="@+id/btn_edit"/>
            <ImageView
                android:id="@+id/btn_ai_permission"
                android:background="@drawable/icon_ai_permission"
                android:visibility="gone"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dp_20"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_ai_model"
            android:background="@color/fragment_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_110"
            android:layout_marginEnd="@dimen/dp_110">
            <TextView
                android:textSize="@dimen/sp_18"
                android:textColor="@color/black_333"
                android:id="@+id/tv_ai_model"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ImageView
                android:id="@+id/img_arrow"
                android:background="@drawable/ic_arrow_down"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_4"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/black_333"
            android:gravity="center"
            android:id="@+id/btn_from_trans"
            android:background="@drawable/bg_radius_purple_8"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"
            android:paddingHorizontal="@dimen/dp_6"
            android:paddingVertical="@dimen/dp_2"/>
    </RelativeLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rl_list"
        android:paddingBottom="@dimen/dp_10"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/rl_bottom"
        app:layout_constraintTop_toBottomOf="@+id/rl_title"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_empty"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/rl_bottom"
        app:layout_constraintTop_toBottomOf="@+id/rl_title">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:visibility="visible"
            android:layout_width="@dimen/dp_202"
            android:layout_height="@dimen/dp_132"
            android:src="@drawable/ic_ai_chat_empty"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_main_text"
            android:layout_gravity="center"
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_32"
            android:text="@string/string_no_ai_talk"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:paddingHorizontal="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_voice_notes_text"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/string_no_ai_talk_tip"
            android:layout_marginHorizontal="@dimen/dp_20"
            android:paddingHorizontal="@dimen/dp_20"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_bottom"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView
            android:textSize="@dimen/sp_10"
            android:textColor="@color/textColor"
            android:id="@+id/tv_ai_tip"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/string_ai_send_tip"
            android:layout_centerHorizontal="true"/>
        <androidx.cardview.widget.CardView
            android:id="@+id/card_start"
            android:background="@drawable/bg_card_white_shape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_2"
            android:layout_marginBottom="@dimen/dp_5"
            android:layout_below="@+id/tv_ai_tip"
            android:layout_marginHorizontal="@dimen/dp_16"
            app:cardCornerRadius="@dimen/dp_12"
            app:cardElevation="3dp"
            app:cardPreventCornerOverlap="true"
            app:cardUseCompatPadding="true">
            <RelativeLayout
                android:id="@+id/btn_start"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_45">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/black_333"
                    android:gravity="center"
                    android:id="@+id/tv_start"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/string_touch_speak"/>
                <ImageView
                    android:id="@+id/iv_touch_img"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_182"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
