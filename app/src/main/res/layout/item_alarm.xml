<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_btn_main"
    android:layout_width="match_parent"
    android:layout_height="@dimen/dp_76"
    android:layout_marginBottom="@dimen/dp_16"
    android:paddingHorizontal="@dimen/dp_16">
    <TextView
        android:textSize="@dimen/sp_20"
        android:textColor="@color/white"
        android:id="@+id/tv_item_alarm_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_12"
        app:layout_constraintBottom_toTopOf="@+id/tv_item_alarm_des"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/color_red_e9"
        android:id="@+id/tv_item_alarm_out_of_date"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/string_out_of_date"
        android:layout_marginStart="@dimen/dp_8"
        app:layout_constraintBottom_toBottomOf="@+id/tv_item_alarm_time"
        app:layout_constraintStart_toEndOf="@+id/tv_item_alarm_time"
        app:layout_constraintTop_toTopOf="@+id/tv_item_alarm_time"/>
    <TextView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/color_8e"
        android:id="@+id/tv_item_alarm_des"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_item_alarm_time"/>
    <ImageView
        android:id="@+id/sw_item_alarm"
        android:background="@drawable/ic_alarm_switch"
        android:layout_width="@dimen/dp_46"
        android:layout_height="@dimen/dp_24"
        android:layout_marginBottom="@dimen/dp_6"
        app:layout_constraintBottom_toTopOf="@+id/btn_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <ImageView
        android:id="@+id/btn_more"
        android:background="@drawable/ic_alarm_more"
        android:layout_width="@dimen/dp_24"
        android:layout_height="@dimen/dp_24"
        android:layout_marginEnd="@dimen/dp_4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sw_item_alarm"/>
</androidx.constraintlayout.widget.ConstraintLayout>
