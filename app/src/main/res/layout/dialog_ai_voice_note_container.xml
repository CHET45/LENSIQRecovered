<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/dp_30"
    android:layout_marginEnd="@dimen/dp_30">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_dialog_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/record_item_title_color"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_parent"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <ProgressBar
                android:layout_gravity="center_horizontal"
                android:id="@+id/progressBar"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/ai_voice_note_dialog_desc_font_color"
                android:gravity="center"
                android:id="@+id/tv_content"
                android:padding="10dp"
                android:visibility="gone"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="64dp"/>
        </LinearLayout>
        <RelativeLayout
            android:layout_gravity="center"
            android:id="@+id/dialog_content_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <View
            android:id="@+id/line_id"
            android:background="@color/ai_voice_note_dialog_line_color"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0.6dp"/>
        <LinearLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/dialog_notify_ll"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="60dp">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/ai_voice_note_dialog_cancel_font_color"
                android:gravity="center"
                android:id="@+id/tv_left"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/ai_voice_note_cancel"
                android:layout_weight="1"/>
            <View
                android:id="@+id/divider_id"
                android:background="@color/ai_voice_note_dialog_line_color"
                android:visibility="gone"
                android:layout_width="0.6dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/record_save_cancel_btn_color"
                android:gravity="center"
                android:id="@+id/tv_right"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="@string/ai_voice_note_confirm"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
