<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_8"
    android:layout_marginBottom="@dimen/dp_8"
    android:layout_marginStart="@dimen/dp_20"
    android:layout_marginEnd="@dimen/dp_20">
    <TextView
        android:textSize="@dimen/sp_12"
        android:textColor="@color/gray_828282"
        android:gravity="center"
        android:id="@+id/time"
        android:padding="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="12:00"
        android:layout_alignParentTop="true"/>
    <ImageView
        android:id="@+id/iv_select"
        android:visibility="visible"
        android:layout_width="@dimen/dp_20"
        android:layout_height="@dimen/dp_20"
        android:src="@drawable/ic_edit_unselect"
        android:layout_alignTop="@+id/item_one"
        android:layout_alignBottom="@+id/item_one"
        android:layout_marginEnd="@dimen/dp_10"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/item_one"
        android:background="@drawable/btn_ai_light_blue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/time"
        android:layout_marginStart="@dimen/dp_30"
        android:layout_alignParentEnd="true">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/black"
            android:id="@+id/tv_name"
            android:padding="@dimen/dp_10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ttttt"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/item_bottom"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_20">
            <ImageView
                android:textColor="@color/white"
                android:id="@+id/img_voice_btn"
                android:background="@drawable/ic_pause"
                android:layout_width="20dp"
                android:layout_height="20dp"/>
            <ImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/img_voice"
                android:paddingLeft="2dp"
                android:paddingRight="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_volume_play"
                android:layout_marginStart="@dimen/dp_10"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/item_two"
        android:background="@drawable/bg_radius_ai_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_below="@+id/item_one"
        android:layout_alignParentStart="true">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/img_load_point"
            android:padding="10dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/text_loadding"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"/>
    </LinearLayout>
</RelativeLayout>
