<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_vertical"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:id="@+id/ll_content"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48">
        <ImageView
            android:id="@+id/iv_back"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/color_main_text"
            android:gravity="center"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/dp_250"
            android:singleLine="true"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_4"
            android:layout_marginEnd="@dimen/dp_20"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_25"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_important_color"
            android:gravity="center_vertical"
            android:id="@+id/btn_from_trans"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:layout_marginTop="@dimen/dp_10"
            android:drawableEnd="@drawable/ic_bv_more"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="10dp"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="#999999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_16"
            android:text="@string/string_my_language"
            android:layout_marginStart="@dimen/dp_20"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/text_important_color"
            android:gravity="center_vertical"
            android:id="@+id/btn_to_trans"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:layout_marginTop="@dimen/dp_10"
            android:drawableEnd="@drawable/ic_bv_more"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="10dp"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="#999999"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_16"
            android:text="@string/string_other_language"
            android:layout_marginStart="@dimen/dp_20"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_135"
        android:layout_marginTop="@dimen/dp_40"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20">
        <FrameLayout
            android:id="@+id/btn_video"
            android:background="@drawable/bg_btn_main"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/dp_6">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/bg_video"
                android:background="@drawable/bg_selected_purple_10_shape"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:background="@drawable/ic_call_video"
                    android:layout_width="@dimen/dp_61"
                    android:layout_height="@dimen/dp_61"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_9"
                    android:text="@string/string_video_call"/>
            </LinearLayout>
        </FrameLayout>
        <FrameLayout
            android:id="@+id/btn_audio"
            android:background="@drawable/bg_btn_main"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/dp_6">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/bg_audio"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:background="@drawable/ic_call_audio"
                    android:layout_width="@dimen/dp_61"
                    android:layout_height="@dimen/dp_61"/>
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/text_important_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_9"
                    android:text="@string/string_voice_call"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
    <TextView
        android:textColor="@color/black"
        android:layout_gravity="center_horizontal"
        android:id="@+id/btn_start"
        android:background="@drawable/btn_base_purple"
        android:paddingTop="@dimen/dp_20"
        android:paddingBottom="@dimen/dp_20"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_80"
        android:text="@string/string_invite_call"
        android:paddingStart="@dimen/dp_57"
        android:paddingEnd="@dimen/dp_57"/>
</LinearLayout>
