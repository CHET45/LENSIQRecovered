<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">
        <FrameLayout
            android:id="@+id/fr_back"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/dp_20">
            <ImageView
                android:layout_gravity="center"
                android:background="@drawable/ic_search_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </FrameLayout>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/record_item_title_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_voice_note_record_list_title"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <com.yanzhenjie.recyclerview.SwipeRecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_15"
        android:layout_below="@+id/rl_title"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_191"
        android:layout_below="@+id/rl_title">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/img_voice_note"
            android:background="@drawable/ic_ai_voice_note_list_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_35"
            android:layout_marginEnd="@dimen/dp_35">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/record_list_empty_view_desc_font_color"
                android:gravity="center"
                android:layout_gravity="center"
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ai_voice_note_view_tip"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_20"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/iv_record"
        android:background="@drawable/ic_trans_voice_mic"
        android:layout_width="@dimen/dp_60"
        android:layout_height="@dimen/dp_60"
        android:layout_marginBottom="@dimen/dp_37"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="@dimen/dp_20"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
