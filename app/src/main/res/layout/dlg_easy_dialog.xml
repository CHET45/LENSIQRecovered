<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:layout_width="@dimen/dp_279"
    android:layout_height="@dimen/dp_195"
    android:layout_marginStart="@dimen/dp_30"
    android:layout_marginEnd="@dimen/dp_30">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/ll_dialog_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/text_important_color"
            android:gravity="center"
            android:id="@+id/dialog_title"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_parent"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <ProgressBar
                android:layout_gravity="center_horizontal"
                android:id="@+id/progressBar"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/white_8F8F8F"
                android:gravity="center"
                android:id="@+id/dialog_message"
                android:padding="10dp"
                android:visibility="visible"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:minHeight="64dp"/>
        </LinearLayout>
        <RelativeLayout
            android:layout_gravity="center"
            android:id="@+id/dialog_content_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <View
            android:id="@+id/line_id"
            android:background="@color/dialog_line"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="0.3dp"/>
        <LinearLayout
            android:gravity="bottom"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:id="@+id/dialog_notify_ll"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="44dp">
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/gray_828282"
                android:gravity="center"
                android:id="@+id/dialog_left_btn"
                android:visibility="visible"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="@string/cancel"
                android:layout_weight="1"/>
            <View
                android:id="@+id/divider_id"
                android:background="@color/dialog_line"
                android:visibility="visible"
                android:layout_width="0.3dp"
                android:layout_height="match_parent"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/base_purple"
                android:gravity="center"
                android:id="@+id/dialog_right_btn"
                android:visibility="visible"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="@string/confirm"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
