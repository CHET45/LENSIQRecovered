<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#eaeaea"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <EditText
            android:id="@+id/xtts_ed_input"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:text="测试一段发音"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp">
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_language_info"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="语种"/>
            <Spinner
                android:id="@+id/xtts_sp_language"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginLeft="10dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp">
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_vcn_info"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="发音人："/>
            <Spinner
                android:id="@+id/xtts_sp_vcn"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginLeft="10dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp">
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_pitch_info"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="语调："/>
            <SeekBar
                android:id="@+id/xtts_sb_pitch"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:max="100"
                android:progress="50"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_pitch_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text="50"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp">
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_speed_info"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="语速："/>
            <SeekBar
                android:id="@+id/xtts_sb_speed"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:max="100"
                android:progress="50"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_speed_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text="50"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="20dp">
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_volume_info"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="音量："/>
            <SeekBar
                android:id="@+id/xtts_sb_volume"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:max="100"
                android:progress="50"/>
            <TextView
                android:textSize="16sp"
                android:textColor="#333333"
                android:id="@+id/xtts_tv_volume_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text="50"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">
            <Button
                android:textSize="18sp"
                android:textColor="#ffffff"
                android:id="@+id/xtts_btn_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="合成并播放"/>
        </LinearLayout>
        <TextView
            android:id="@+id/xtts_tv_showinfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>
