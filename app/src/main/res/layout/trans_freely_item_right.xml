<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_10"
    android:layout_marginBottom="@dimen/dp_15"
    android:layout_marginStart="@dimen/dp_20"
    android:layout_marginEnd="@dimen/dp_20">
    <ImageView
        android:id="@+id/iv_select"
        android:background="@drawable/ic_edit_unselect"
        android:visibility="gone"
        android:layout_width="@dimen/dp_20"
        android:layout_height="@dimen/dp_20"
        android:layout_centerVertical="true"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/layout_test"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true">
        <ImageView
            android:id="@+id/img_polygon"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_right_polygon"
            android:layout_marginEnd="@dimen/dp_6"
            android:layout_toStartOf="@+id/img_ear"/>
        <ImageView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/text_important_color_new"
            android:id="@+id/img_ear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_phone_purple"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="right"
        android:orientation="vertical"
        android:id="@+id/item_ear"
        android:background="@drawable/btn_ai_trans_right"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp_26"
        android:layout_toStartOf="@+id/layout_test"
        android:paddingHorizontal="@dimen/dp_16">
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_line"
            android:gravity="center_vertical"
            android:id="@+id/ear_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ttttt"
            android:paddingVertical="@dimen/dp_10"/>
        <View
            android:id="@+id/view_line"
            android:background="@color/color_line_right"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="0.2dp"/>
        <TextView
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_dialog_bg"
            android:id="@+id/ear_trans_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ttttt"
            android:paddingVertical="@dimen/dp_10"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/receive_item_bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_m_6">
            <LinearLayout
                android:layout_gravity="start|center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="30dp">
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/receive_img_voice"
                    android:background="@drawable/ic_volume_ai_play"
                    android:paddingLeft="2dp"
                    android:paddingRight="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dp_6"/>
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/receive_img_voice_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_trans_playing_btn"
                    android:scaleType="centerInside"
                    android:paddingEnd="@dimen/dp_6"/>
            </LinearLayout>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/text_important_color_new"
                android:gravity="end|center_vertical"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/translate_text"
                android:padding="10dp"
                android:paddingLeft="2dp"
                android:paddingRight="2dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:layout_marginTop="20dp"
                android:text="翻译"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
