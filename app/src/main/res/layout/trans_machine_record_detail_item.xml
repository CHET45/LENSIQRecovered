<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/dp_20">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/ll_language"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_44"
        android:layout_marginBottom="@dimen/dp_6">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_black_33"
            android:id="@+id/tv_source_language"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="中文"/>
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_record_lanuage_exchanage"
            android:layout_marginHorizontal="@dimen/dp_6"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_black_33"
            android:id="@+id/tv_trans_language"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="英文"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_6">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_record_language"
            android:layout_marginEnd="@dimen/dp_6"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/color_gray_aeaeb2"
            android:id="@+id/tv_current_language"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="英文"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/color_black_33"
        android:id="@+id/tv_source_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/gray_999999"
        android:id="@+id/tv_trans_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_2"
        android:layout_marginBottom="@dimen/dp_22"/>
</LinearLayout>
