<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="@drawable/shape_custom_dialog_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/dp_16"
    android:paddingEnd="@dimen/dp_16">
    <ImageView
        android:id="@+id/iv_bar"
        android:layout_width="43dp"
        android:layout_height="4dp"
        android:layout_marginTop="@dimen/dp_12"
        android:src="@drawable/ic_timing_dialog_top_bar"
        android:layout_centerHorizontal="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/dp_18"
        android:textColor="@color/text_important_color"
        android:gravity="center"
        android:id="@+id/tv_language_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_32"
        android:text="@string/rename"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_bar"/>
    <RelativeLayout
        android:id="@+id/rl_title"
        android:background="@drawable/dialog_edit_voice_notes_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_language_title">
        <EditText
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/text_important_color"
            android:textColorHint="@color/gray_828282"
            android:id="@+id/et_title"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_marginBottom="@dimen/dp_20"
            android:hint="@string/record_title_maxlength"
            android:maxLength="50"
            android:layout_centerVertical="true"
            android:paddingEnd="@dimen/dp_36"
            android:layout_marginStart="@dimen/dp_16"/>
        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            android:src="@drawable/ic_dialog_cancel"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_16"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="?attr/imgbg"
        android:gravity="center"
        android:id="@+id/tv_cancel"
        android:background="@drawable/btn_base_left"
        android:paddingTop="@dimen/dp_13"
        android:paddingBottom="@dimen/dp_13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_96"
        android:layout_marginBottom="@dimen/dp_24"
        android:minWidth="@dimen/dp_120"
        android:text="@string/cancel"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_23"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_sure"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rl_title"/>
    <TextView
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/tv_sure"
        android:background="@drawable/btn_base_purple"
        android:paddingTop="@dimen/dp_13"
        android:paddingBottom="@dimen/dp_13"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_96"
        android:minWidth="@dimen/dp_120"
        android:text="@string/confirm"
        android:paddingStart="@dimen/dp_30"
        android:paddingEnd="@dimen/dp_30"
        android:layout_marginStart="@dimen/dp_23"
        android:layout_marginEnd="@dimen/dp_30"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tv_cancel"
        app:layout_constraintTop_toBottomOf="@+id/rl_title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
