<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top_opera"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_image_back"
            android:layout_marginStart="@dimen/dp_20"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <RelativeLayout
            android:id="@+id/rl_end_opera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/dp_20"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/iv_back">
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/base_purple"
                app:cardCornerRadius="@dimen/dp_16"
                app:cardElevation="@dimen/dp_0">
                <TextView
                    android:textSize="@dimen/text_14sp"
                    android:textColor="@color/t_191B1D"
                    android:paddingTop="@dimen/dp_7"
                    android:paddingBottom="@dimen/dp_7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/string_save"
                    android:paddingStart="@dimen/dp_17"
                    android:paddingEnd="@dimen/dp_17"/>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_recover"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/base_purple"
                app:cardCornerRadius="@dimen/dp_16"
                app:cardElevation="@dimen/dp_0">
                <TextView
                    android:textSize="@dimen/text_14sp"
                    android:textColor="@color/t_191B1D"
                    android:paddingTop="@dimen/dp_7"
                    android:paddingBottom="@dimen/dp_7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reset"
                    android:paddingStart="@dimen/dp_17"
                    android:paddingEnd="@dimen/dp_17"/>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>
        <ImageView
            android:id="@+id/iv_retry"
            android:padding="@dimen/dp_5"
            android:layout_width="@dimen/dp_34"
            android:layout_height="@dimen/dp_34"
            android:src="@drawable/ic_image_retry"
            android:layout_marginEnd="@dimen/dp_11"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintEnd_toStartOf="@+id/rl_end_opera"
            app:layout_constraintTop_toTopOf="@+id/iv_back"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/ll_image_edit"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_20"
        android:layout_marginHorizontal="@dimen/dp_40"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/btn_img_tailor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:background="@drawable/ic_image_tailor"
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/color_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crop"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/btn_img_filter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:background="@drawable/ic_image_filter"
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/color_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@+id/btn_img_adjust"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:background="@drawable/ic_image_adjust"
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"/>
            <TextView
                android:textSize="@dimen/sp_10"
                android:textColor="@color/color_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/adjust"/>
        </LinearLayout>
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_bottom_opera"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_image_crop"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ll_scale_orientation"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp_12"
                app:layout_constraintBottom_toTopOf="@+id/ll_image_crop_bottom_opera"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                <ImageView
                    android:id="@+id/iv_scale_vertical"
                    android:layout_width="@dimen/dp_28"
                    android:layout_height="@dimen/dp_28"
                    android:src="@drawable/ic_image_vertical_selected"/>
                <ImageView
                    android:id="@+id/iv_scale_landscape"
                    android:layout_width="@dimen/dp_28"
                    android:layout_height="@dimen/dp_28"
                    android:src="@drawable/ic_image_landscape"
                    android:layout_marginStart="@dimen/dp_12"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_image_crop_bottom_opera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent">
                <androidx.cardview.widget.CardView
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/cv_scale_detail"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="@dimen/dp_12"
                    android:layout_marginStart="@dimen/dp_20"
                    android:layout_marginEnd="@dimen/dp_20"
                    app:cardBackgroundColor="@color/color_000000"
                    app:cardCornerRadius="@dimen/dp_38">
                    <HorizontalScrollView
                        android:id="@+id/hsv_ratio"
                        android:scrollbars="none"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="never"
                        android:layout_marginStart="@dimen/dp_16"
                        android:layout_marginEnd="@dimen/dp_16">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent">
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_ecf3f3"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_original_ratio"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/original_ratio"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_free_ratio"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/free_ratio"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_1_1"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1:1"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_4_3"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4:3"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_3_4"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3:4"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_9_16"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="9:16"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_16_9"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="16:9"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_2_3"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2:3"
                                android:layout_marginStart="@dimen/dp_10"/>
                            <TextView
                                android:textSize="@dimen/text_12sp"
                                android:textColor="@color/t_818588"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_ratio_3_2"
                                android:padding="@dimen/dp_10"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3:2"
                                android:layout_marginStart="@dimen/dp_10"/>
                        </LinearLayout>
                    </HorizontalScrollView>
                </androidx.cardview.widget.CardView>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:background="@color/color_000000"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/ll_fun1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_16"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_rotation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/iv_rotate_check"
                                android:layout_width="@dimen/dp_24"
                                android:layout_height="@dimen/dp_24"
                                android:src="@drawable/ic_image_rotate"/>
                            <TextView
                                android:textSize="@dimen/text_10sp"
                                android:textColor="@color/t_ecf3f3"
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/tv_rotate_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_4"
                                android:text="@string/rotate"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_mirror"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dp_74">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/iv_mirror_check"
                                android:layout_width="@dimen/dp_24"
                                android:layout_height="@dimen/dp_24"
                                android:src="@drawable/ic_image_mirror"/>
                            <TextView
                                android:textSize="@dimen/text_10sp"
                                android:textColor="@color/t_ecf3f3"
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/tv_mirror_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_4"
                                android:text="@string/mirror"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="vertical"
                            android:id="@+id/ll_ratio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/dp_74">
                            <ImageView
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/iv_ratio_check"
                                android:layout_width="@dimen/dp_24"
                                android:layout_height="@dimen/dp_24"
                                android:src="@drawable/ic_image_scale"/>
                            <TextView
                                android:textSize="@dimen/text_10sp"
                                android:textColor="@color/t_ecf3f3"
                                android:layout_gravity="center_horizontal"
                                android:id="@+id/tv_ratio_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_4"
                                android:text="@string/ratio"/>
                        </LinearLayout>
                    </LinearLayout>
                    <ImageView
                        android:id="@+id/iv_image_crop_cancel"
                        android:padding="@dimen/dp_5"
                        android:layout_width="@dimen/dp_34"
                        android:layout_height="@dimen/dp_34"
                        android:layout_marginTop="@dimen/dp_7"
                        android:src="@drawable/ic_image_cancel"
                        android:layout_marginStart="@dimen/dp_15"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ll_fun1"/>
                    <ImageView
                        android:id="@+id/iv_image_crop_submit"
                        android:padding="@dimen/dp_5"
                        android:layout_width="@dimen/dp_34"
                        android:layout_height="@dimen/dp_34"
                        android:layout_marginTop="@dimen/dp_7"
                        android:src="@drawable/ic_image_submit"
                        android:layout_marginEnd="@dimen/dp_15"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ll_fun1"/>
                    <View
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/dp_30"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_image_crop_cancel"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/iv_image_crop_comparison"
                android:padding="@dimen/dp_5"
                android:layout_width="@dimen/dp_34"
                android:layout_height="@dimen/dp_34"
                android:layout_marginBottom="@dimen/dp_20"
                android:src="@drawable/ic_image_comparison"
                android:layout_marginEnd="@dimen/dp_15"
                app:layout_constraintBottom_toTopOf="@+id/ll_image_crop_bottom_opera"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_image_filter"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_image_filter_bottom_opera"
                android:background="@color/color_000000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent">
                <HorizontalScrollView
                    android:id="@+id/hsv_filter"
                    android:scrollbars="none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_13"
                    android:overScrollMode="never"
                    android:layout_marginStart="@dimen/dp_20"
                    android:layout_marginEnd="@dimen/dp_20"
                    app:layout_constraintTop_toTopOf="parent">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/ll_fun_stylefilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </HorizontalScrollView>
                <ImageView
                    android:id="@+id/iv_image_filter_cancel"
                    android:padding="@dimen/dp_5"
                    android:layout_width="@dimen/dp_34"
                    android:layout_height="@dimen/dp_34"
                    android:layout_marginTop="@dimen/dp_7"
                    android:src="@drawable/ic_image_cancel"
                    android:layout_marginStart="@dimen/dp_15"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/hsv_filter"/>
                <ImageView
                    android:id="@+id/iv_image_filter_submit"
                    android:padding="@dimen/dp_5"
                    android:layout_width="@dimen/dp_34"
                    android:layout_height="@dimen/dp_34"
                    android:layout_marginTop="@dimen/dp_7"
                    android:src="@drawable/ic_image_submit"
                    android:layout_marginEnd="@dimen/dp_15"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/hsv_filter"/>
                <View
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_30"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/iv_image_filter_cancel"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <ImageView
                android:id="@+id/iv_image_filter_comparison"
                android:padding="@dimen/dp_5"
                android:layout_width="@dimen/dp_34"
                android:layout_height="@dimen/dp_34"
                android:src="@drawable/ic_image_comparison"
                android:layout_marginEnd="@dimen/dp_15"
                app:layout_constraintBottom_toTopOf="@+id/cl_image_filter_bottom_opera"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_image_adjust"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_image_adjust_bottom_opera"
                android:background="@color/color_000000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/ll_fun3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_13"
                    app:layout_constraintTop_toTopOf="parent">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/ll_adjust_auto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <ImageView
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/iv_adjust_auto"
                            android:layout_width="@dimen/dp_24"
                            android:layout_height="@dimen/dp_24"
                            android:src="@drawable/ic_image_auto"/>
                        <TextView
                            android:textSize="@dimen/text_10sp"
                            android:textColor="@color/t_ecf3f3"
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/tv_adjust_auto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_4"
                            android:text="@string/auto"/>
                        <View
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/v_adjust_auto"
                            android:background="@drawable/shape_ffd100_bg"
                            android:visibility="gone"
                            android:layout_width="@dimen/dp_2"
                            android:layout_height="@dimen/dp_2"
                            android:layout_marginTop="@dimen/dp_9"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/ll_adjust_brightness"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <ImageView
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/iv_adjust_brightness"
                            android:layout_width="@dimen/dp_24"
                            android:layout_height="@dimen/dp_24"
                            android:src="@drawable/ic_image_brightness"/>
                        <TextView
                            android:textSize="@dimen/text_10sp"
                            android:textColor="@color/t_ecf3f3"
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/tv_adjust_brightness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_4"
                            android:text="@string/eyevue_brightness"/>
                        <View
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/v_adjust_brightness"
                            android:background="@drawable/shape_ffd100_bg"
                            android:visibility="gone"
                            android:layout_width="@dimen/dp_2"
                            android:layout_height="@dimen/dp_2"
                            android:layout_marginTop="@dimen/dp_9"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/ll_adjust_contrast"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <ImageView
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/iv_adjust_contrast"
                            android:layout_width="@dimen/dp_24"
                            android:layout_height="@dimen/dp_24"
                            android:src="@drawable/ic_image_contrast"/>
                        <TextView
                            android:textSize="@dimen/text_10sp"
                            android:textColor="@color/t_ecf3f3"
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/tv_adjust_contrast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_4"
                            android:text="@string/contrast"/>
                        <View
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/v_adjust_contrast"
                            android:background="@drawable/shape_ffd100_bg"
                            android:visibility="gone"
                            android:layout_width="@dimen/dp_2"
                            android:layout_height="@dimen/dp_2"
                            android:layout_marginTop="@dimen/dp_9"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/ll_adjust_saturation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <ImageView
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/iv_adjust_saturation"
                            android:layout_width="@dimen/dp_24"
                            android:layout_height="@dimen/dp_24"
                            android:src="@drawable/ic_image_saturability"/>
                        <TextView
                            android:textSize="@dimen/text_10sp"
                            android:textColor="@color/t_ecf3f3"
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/tv_adjust_saturation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
