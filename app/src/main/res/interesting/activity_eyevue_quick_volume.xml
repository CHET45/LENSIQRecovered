<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:paddingHorizontal="@dimen/dp_20"
        android:paddingVertical="@dimen/dp_16">
        <ImageView
            android:id="@+id/iv_media"
            android:background="@drawable/icon_sound_media"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_video"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_media"
            android:layout_marginStart="@dimen/dp_14"
            app:layout_constraintBottom_toBottomOf="@+id/iv_media"
            app:layout_constraintStart_toEndOf="@+id/iv_media"
            app:layout_constraintTop_toTopOf="@+id/iv_media"/>
        <SeekBar
            android:id="@+id/pb_media"
            android:background="@null"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_16"
            android:maxHeight="@dimen/dp_16"
            android:max="16"
            android:progress="0"
            android:secondaryProgress="0"
            android:progressDrawable="@drawable/sound_progress_base"
            android:thumb="@null"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:splitTrack="false"
            app:layout_constraintTop_toBottomOf="@+id/iv_media"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:paddingHorizontal="@dimen/dp_20"
        android:paddingVertical="@dimen/dp_16">
        <ImageView
            android:id="@+id/iv_system"
            android:background="@drawable/icon_sound_system"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_video"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_system"
            android:layout_marginStart="@dimen/dp_14"
            app:layout_constraintBottom_toBottomOf="@+id/iv_system"
            app:layout_constraintStart_toEndOf="@+id/iv_system"
            app:layout_constraintTop_toTopOf="@+id/iv_system"/>
        <SeekBar
            android:id="@+id/pb_system"
            android:background="@null"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_16"
            android:maxHeight="@dimen/dp_16"
            android:max="15"
            android:progress="0"
            android:secondaryProgress="0"
            android:progressDrawable="@drawable/sound_progress_base"
            android:thumb="@null"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:splitTrack="false"
            app:layout_constraintTop_toBottomOf="@+id/iv_system"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginHorizontal="@dimen/dp_20"
        android:paddingHorizontal="@dimen/dp_20"
        android:paddingVertical="@dimen/dp_16">
        <ImageView
            android:id="@+id/iv_call"
            android:background="@drawable/icon_sound_call"
            android:layout_width="@dimen/dp_20"
            android:layout_height="@dimen/dp_20"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_video"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_call"
            android:layout_marginStart="@dimen/dp_14"
            app:layout_constraintBottom_toBottomOf="@+id/iv_call"
            app:layout_constraintStart_toEndOf="@+id/iv_call"
            app:layout_constraintTop_toTopOf="@+id/iv_call"/>
        <SeekBar
            android:id="@+id/pb_call"
            android:background="@null"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_16"
            android:layout_marginTop="@dimen/dp_16"
            android:maxHeight="@dimen/dp_16"
            android:max="15"
            android:progress="0"
            android:secondaryProgress="0"
            android:progressDrawable="@drawable/sound_progress_base"
            android:thumb="@null"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:splitTrack="false"
            app:layout_constraintTop_toBottomOf="@+id/iv_call"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
