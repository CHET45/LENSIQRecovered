<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_18sp"
            android:textStyle="bold"
            android:textColor="@color/color_main_text"
            android:gravity="center"
            android:layout_gravity="right"
            android:id="@+id/skip_login"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="@dimen/dp_10"
            android:minWidth="@dimen/dp_50"
            android:text="@string/eyevue_skip"
            android:paddingStart="@dimen/dp_5"
            android:paddingEnd="@dimen/dp_5"
            android:layout_marginEnd="@dimen/dp_16"/>
        <com.eyevue.common.widget.BvImageView
            android:layout_width="@dimen/dp_115"
            android:layout_height="@dimen/dp_115"
            android:layout_marginTop="@dimen/dp_110"
            android:src="@drawable/lensiq_logo"
            android:scaleType="fitXY"
            app:radius="10dp"/>
        <TextView
            android:textSize="@dimen/text_22sp"
            android:textStyle="bold"
            android:textColor="@color/color_main_text"
            android:id="@+id/add_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/app_name"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_24"
            android:layout_marginHorizontal="@dimen/dp_24">
            <com.eyevue.common.widget.MyEditText
                android:textSize="@dimen/text_14sp"
                android:textColor="@color/color_main_text"
                android:textColorHint="@color/color_voice_notes_text"
                android:id="@+id/et_phone_number"
                android:background="@drawable/bg_edit_auth"
                android:padding="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_50"
                android:hint="@string/eyevue_hint_input_phone_number"
                android:maxLength="100"
                android:textCursorDrawable="@null"
                android:textAlignment="viewStart"/>
            <ImageView
                android:id="@+id/iv_phone_clean"
                android:padding="@dimen/dp_8"
                android:layout_width="@dimen/dp_36"
                android:layout_height="@dimen/dp_36"
                android:src="@drawable/ic_close"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/color_main_text"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tv_send_sms"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:layout_marginTop="@dimen/dp_24"
            android:text="@string/eyevue_send_sms_code"
            android:layout_marginHorizontal="@dimen/dp_24"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="horizontal"
            android:id="@+id/ll_user_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_marginHorizontal="@dimen/dp_44">
            <CheckBox
                android:id="@+id/checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/selector_checkbox"/>
            <TextView
                android:textSize="@dimen/text_12sp"
                android:textColor="@color/color_voice_notes_text"
                android:id="@+id/tv_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </LinearLayout>
</FrameLayout>
