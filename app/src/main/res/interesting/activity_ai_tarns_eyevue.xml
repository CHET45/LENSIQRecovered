<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_54"
        android:layout_marginHorizontal="@dimen/dp_20">
        <ImageView
            android:id="@+id/iv_back_btn"
            android:visibility="visible"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/ic_search_back"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/color_main_text"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/dp_180"
            android:text="@string/trans_ear_glasses_tip"
            android:singleLine="true"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_4"
            android:layout_marginEnd="@dimen/dp_4"/>
        <ImageView
            android:id="@+id/btn_edit"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:src="@drawable/icon_album_edit"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/title_layout"
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_54"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_below="@+id/title"
        android:layout_marginHorizontal="@dimen/dp_16">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_main_text"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/btn_from_trans"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:drawableEnd="@drawable/ic_drop_down"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="@dimen/dp_30"
            android:layout_toStartOf="@+id/img_exchange"
            android:paddingHorizontal="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_main_text"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/btn_to_trans"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:drawableEnd="@drawable/ic_drop_down"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="@dimen/dp_30"
            android:layout_toEndOf="@+id/img_exchange"/>
        <ImageView
            android:id="@+id/img_exchange"
            android:padding="10dp"
            android:visibility="visible"
            android:layout_width="@dimen/dp_38"
            android:layout_height="@dimen/dp_36"
            android:src="@drawable/ic_exchange"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/rl_bottom"
        android:layout_below="@+id/title_layout">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ai_demo_rc"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_10"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:layout_weight="1"
            android:fadeScrollbars="false"
            android:overScrollMode="never"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/buttom_view"
            android:background="@drawable/bg_btn_main_base_purple"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_48"
            android:layout_marginBottom="@dimen/dp_20"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_30">
            <TextView
                android:textSize="@dimen/text_14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/btn_phone_voice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/dp_15"
                android:drawableStart="@drawable/ic_trans_voice_black"
                android:layout_marginStart="@dimen/dp_12"/>
            <TextView
                android:textSize="@dimen/sp_12"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@+id/btn_ear_send"
                android:background="@drawable/btn_base_purple"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_48"
                android:text="眼镜"
                android:layout_marginStart="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_5"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:id="@+id/voice_view"
            android:background="@drawable/ai_trans_dialog_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/dp_102">
            <TextView
                android:enabled="true"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                android:textColor="@color/color_main_text"
                android:textColorHint="@color/color_main_text"
                android:gravity="center"
                android:id="@+id/txt_voice_value"
                android:background="@null"
                android:clickable="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:hint="@string/str_recorder_dialog_tip"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/img_voice"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_45"
                android:layout_marginTop="@dimen/dp_8"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/text_important_color_new"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_8"
                android:layout_marginBottom="@dimen/dp_10"
                android:text="@string/click_to_stop"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"/>
        </LinearLayout>
        <com.watchfun.transcommon.widget.BottomEditView
            android:id="@+id/bottomEditView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_100"
        android:layout_below="@+id/title_layout">
        <ImageView
            android:id="@+id/img_trans_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_200"
            android:layout_marginStart="@dimen/dp_40"
            android:layout_marginEnd="@dimen/dp_40"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_30"
            android:layout_marginStart="@dimen/dp_35"
            android:layout_marginEnd="@dimen/dp_35">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/text_important_color_new"
                android:id="@+id/txt_empty_trans_tip"
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:text="@string/ai_tarns_empty"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_marginEnd="@dimen/dp_20"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
