<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/main_layout"
    android:background="@color/tab_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/layout"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.eyevue.common.widget.NoScrollViewPager
            android:id="@+id/vp_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <com.eyevue.common.widget.bottomnav.BottomBarLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/bottom_bar"
            android:background="@drawable/trans_home_tab_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_60"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:paddingHorizontal="@dimen/dp_10">
            <com.eyevue.common.widget.bottomnav.BottomBarItem
                android:id="@+id/home_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:iconHeight="@dimen/home_tab_icon_size"
                app:iconNormal="@drawable/ic_home_unselect"
                app:iconSelected="@drawable/ic_home_select"
                app:iconWidth="@dimen/home_tab_icon_size"
                app:itemMarginTop="2dp"
                app:itemText="@string/eyevue_main_home_text"
                app:itemTextSize="@dimen/dp_0"
                app:textColorNormal="@color/color_voice_notes_text"
                app:textColorSelected="@color/main_tab_text_normal"/>
            <com.eyevue.common.widget.bottomnav.BottomBarItem
                android:id="@+id/ai_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:iconHeight="@dimen/home_tab_icon_size"
                app:iconNormal="@drawable/ic_ai_unselect"
                app:iconSelected="@drawable/ic_ai_select"
                app:iconWidth="@dimen/home_tab_icon_size"
                app:itemMarginTop="2dp"
                app:itemText="@string/string_main_ai"
                app:itemTextSize="@dimen/dp_0"
                app:textColorNormal="@color/color_voice_notes_text"
                app:textColorSelected="@color/main_tab_text_normal"/>
            <com.eyevue.common.widget.bottomnav.BottomBarItem
                android:id="@+id/photo_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:iconHeight="@dimen/home_tab_icon_size"
                app:iconNormal="@drawable/ic_album_unselect"
                app:iconSelected="@drawable/ic_album_select"
                app:iconWidth="@dimen/home_tab_icon_size"
                app:itemMarginTop="2dp"
                app:itemText="@string/string_main_album"
                app:itemTextSize="@dimen/dp_0"
                app:textColorNormal="@color/color_voice_notes_text"
                app:textColorSelected="@color/main_tab_text_normal"/>
            <com.eyevue.common.widget.bottomnav.BottomBarItem
                android:id="@+id/minetab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:iconHeight="@dimen/home_tab_icon_size"
                app:iconNormal="@drawable/ic_mine_unselect"
                app:iconSelected="@drawable/ic_mine_select"
                app:iconWidth="@dimen/home_tab_icon_size"
                app:itemMarginTop="2dp"
                app:itemText="@string/eyevue_main_mine_text"
                app:itemTextSize="@dimen/dp_0"
                app:textColorNormal="@color/color_voice_notes_text"
                app:textColorSelected="@color/main_tab_text_normal"/>
        </com.eyevue.common.widget.bottomnav.BottomBarLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/layout_edit"
            android:background="@drawable/trans_home_tab_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_60"
            android:layout_marginBottom="@dimen/dp_10"
            android:weightSum="3"
            android:layout_marginHorizontal="@dimen/dp_16">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_download"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/ic_album_save"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/color_main_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_4"
                    android:text="@string/download"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_delete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/ic_album_delete"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/color_main_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_4"
                    android:text="@string/delete"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_selected_all"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/ic_album_select_all"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/color_main_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_4"
                    android:text="@string/select_all"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/layout_ai_edit"
            android:background="@drawable/trans_home_tab_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_60"
            android:layout_marginBottom="@dimen/dp_10"
            android:weightSum="3"
            android:layout_marginHorizontal="@dimen/dp_16">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_ai_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/icon_select_cancel"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/color_main_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_4"
                    android:text="@string/cancel"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_ai_delete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/ic_album_delete"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/color_main_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_4"
                    android:text="@string/delete"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/ll_ai_selected_all"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/ic_album_select_all"/>
                <TextView
                    android:textSize="@dimen/sp_10"
                    android:textColor="@color/color_main_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_4"
                    android:text="@string/select_all"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
