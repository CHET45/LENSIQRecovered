<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">
        <ImageView
            android:id="@+id/iv_share"
            android:padding="@dimen/dp_12"
            android:visibility="gone"
            android:layout_width="@dimen/dp_50"
            android:layout_height="@dimen/dp_50"
            android:src="@drawable/ic_share"
            android:layout_marginEnd="@dimen/dp_8"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:id="@+id/fr_back"
            android:background="@drawable/ic_search_back"
            android:padding="@dimen/dp_35"
            android:visibility="visible"
            android:layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_18"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/ai_voice_note_list_title_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_voice_note_record_record_detail"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginBottom="@dimen/dp_44"
        android:layout_above="@+id/rl_edit"
        android:layout_below="@+id/rl_title"
        android:layout_marginHorizontal="@dimen/dp_16">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/ai_voice_note_list_title_color"
                    android:id="@+id/edt_lang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentEnd="true"/>
                <TextView
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/ai_voice_note_list_title_color"
                    android:id="@+id/edt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toLeftOf="@+id/edt_lang"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/dp_20"
                    android:layout_alignParentStart="true"/>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/ai_voice_note_list_time_color"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_12"
                android:text="2024年9月14日 21:06"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/shape_ai_voice_note_record_details_v1_bg"
            android:padding="@dimen/dp_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12">
            <pl.droidsonroids.gif.GifImageView
                android:layout_gravity="center_vertical"
                android:id="@+id/sv_wave"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_40"
                android:scaleType="fitXY"/>
            <com.watchfun.voicenotes.widget.CustomSeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_16"
                android:layout_marginTop="@dimen/dp_16"
                app:ballColor="@color/ai_voice_note_record_detail_ball_color"
                app:progressBgColor="@color/ai_voice_note_record_detail_progress_bg_color"
                app:progressColor="@color/ai_voice_note_record_detail_progress_color"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_24">
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/ai_voice_note_list_time_color"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_current_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/iv_before"
                    android:padding="@dimen/dp_10"
                    android:layout_width="@dimen/dp_42"
                    android:layout_height="@dimen/dp_42"
                    android:src="@drawable/ic_play_before"
                    android:layout_marginEnd="@dimen/dp_18"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_play"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/ic_play_start_v1"/>
                <ImageView
                    android:id="@+id/iv_after"
                    android:padding="@dimen/dp_10"
                    android:layout_width="@dimen/dp_42"
                    android:layout_height="@dimen/dp_42"
                    android:src="@drawable/ic_play_after"
                    android:layout_marginStart="@dimen/dp_18"/>
                <TextView
                    android:textSize="@dimen/sp_12"
                    android:textColor="@color/ai_voice_note_list_time_color"
                    android:gravity="end"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/tv_current_total"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:layout_weight="1"/>
            </LinearLayout>
        </LinearLayout>
        <ScrollView
            android:id="@+id/scroll_view"
            android:background="@drawable/shape_ai_voice_note_record_details_v1_bg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/ai_voice_note_list_title_color"
                    android:textColorHint="@color/ai_voice_note_list_title_color"
                    android:id="@+id/tv_current_index"
                    android:padding="@dimen/dp_16"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="@dimen/dp_1"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_edit"
        android:background="@drawable/edit_icon_v1"
        android:layout_width="@dimen/dp_64"
        android:layout_height="@dimen/dp_64"
        android:layout_marginBottom="@dimen/dp_44"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="@dimen/dp_20"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
