<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20">
        <TextView
            android:textSize="@dimen/set_text_size"
            android:textColor="@color/text_important_color_new"
            android:gravity="center_vertical"
            android:id="@+id/tv_user_agreement"
            android:background="@drawable/trans_home_item_bg"
            android:padding="@dimen/dp_20"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ad_icon_height"
            android:text="@string/eyevue_user_agreement"
            android:drawablePadding="@dimen/dp_10"
            android:drawableEnd="@drawable/ic_bv_more"/>
        <TextView
            android:textSize="@dimen/set_text_size"
            android:textColor="@color/text_important_color_new"
            android:gravity="center_vertical"
            android:id="@+id/privacy_agreement"
            android:background="@drawable/trans_home_item_bg"
            android:padding="@dimen/dp_20"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ad_icon_height"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/eyevue_privacy_agreement"
            android:drawablePadding="@dimen/dp_10"
            android:drawableEnd="@drawable/ic_bv_more"/>
        <TextView
            android:textSize="@dimen/set_text_size"
            android:textColor="@color/text_important_color_new"
            android:gravity="center_vertical"
            android:id="@+id/log_off"
            android:background="@drawable/trans_home_item_bg"
            android:padding="@dimen/dp_20"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ad_icon_height"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/eyevue_log_off"
            android:drawablePadding="@dimen/dp_10"
            android:drawableEnd="@drawable/ic_bv_more"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/text_18sp"
        android:textColor="@color/red_prominence"
        android:gravity="center"
        android:id="@+id/log_out"
        android:background="@drawable/bg_radius_red"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_56"
        android:layout_margin="@dimen/dp_20"
        android:text="@string/eyevue_log_out"/>
</LinearLayout>
