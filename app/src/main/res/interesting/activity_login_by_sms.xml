<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/app_background_color_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_15sp"
            android:textColor="@color/base_purple"
            android:gravity="center"
            android:id="@+id/skip_login"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="@dimen/dp_30"
            android:minWidth="@dimen/dp_50"
            android:text="@string/eyevue_skip"
            android:paddingStart="@dimen/dp_5"
            android:paddingEnd="@dimen/dp_5"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:id="@+id/img_login"
            android:layout_width="@dimen/dp_115"
            android:layout_height="@dimen/dp_115"
            android:layout_marginTop="@dimen/dp_40"
            android:src="@drawable/lensiq_logo"
            android:scaleType="fitXY"
            android:layout_below="@+id/skip_login"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="@dimen/dp_22"
            android:layout_marginEnd="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/text_24sp"
            android:textStyle="bold"
            android:textColor="@color/ai_tab_icon"
            android:id="@+id/send_sms_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_86"
            android:text="@string/login_phone"
            android:layout_below="@+id/img_login"
            android:layout_marginStart="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/text_14sp"
            android:id="@+id/text_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/send_sms_title"
            android:layout_marginStart="@dimen/dp_22"
            android:layout_marginEnd="@dimen/dp_20"/>
        <com.eyevue.common.widget.MyEditText
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/text_important_color_new"
            android:id="@+id/et_phone_number"
            android:background="@drawable/feedback_content_bg"
            android:padding="@dimen/dp_10"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_64"
            android:layout_marginTop="@dimen/dp_20"
            android:hint="@string/eyevue_hint_input_phone_number"
            android:maxLength="100"
            android:layout_below="@+id/text_email"
            android:textCursorDrawable="@null"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/sms_layout"
            android:background="@drawable/feedback_content_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_64"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_below="@+id/et_phone_number"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20">
            <TextView
                android:textSize="@dimen/text_16sp"
                android:textColor="@color/base_purple"
                android:ellipsize="end"
                android:id="@+id/tv_send_sms"
                android:paddingLeft="@dimen/dp_12"
                android:paddingTop="@dimen/dp_6"
                android:paddingRight="@dimen/dp_12"
                android:paddingBottom="@dimen/dp_6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/dp_200"
                android:text="@string/eyevue_send_sms_code"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"/>
            <EditText
                android:textSize="@dimen/text_16sp"
                android:textColor="@color/text_important_color_new"
                android:ellipsize="end"
                android:id="@+id/et_verification_code"
                android:background="@null"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/dp_200"
                android:hint="@string/eyevue_input_verification_code"
                android:layout_centerVertical="true"
                android:inputType="number"
                android:layout_toStartOf="@+id/tv_send_sms"/>
        </RelativeLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="horizontal"
            android:id="@+id/ll_user_service"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_60"
            android:layout_below="@+id/sms_layout"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20">
            <CheckBox
                android:id="@+id/checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/selector_checkbox"/>
            <TextView
                android:textSize="@dimen/text_15sp"
                android:textColor="@color/gray_999999"
                android:id="@+id/tv_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.AppCompatButton
            android:enabled="false"
            android:textSize="@dimen/text_18sp"
            android:textColor="@drawable/bg_btn_text_selector"
            android:id="@+id/btn_login"
            android:background="@drawable/bg_btn_purple_gray_selector"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_56"
            android:layout_marginTop="@dimen/dp_50"
            android:text="@string/eyevue_login"
            android:layout_below="@+id/ll_user_service"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"
            style="?android:attr/borderlessButtonStyle"/>
    </RelativeLayout>
</FrameLayout>
