<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_player_control_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_14">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:paddingHorizontal="@dimen/dp_15">
            <ImageView
                android:id="@+id/iv_video_play"
                android:layout_width="@dimen/dp_40"
                android:layout_height="@dimen/dp_40"
                android:src="@drawable/ic_control_play"
                android:layout_centerVertical="true"/>
            <com.eyevue.glassapp.view.photo.DefaultTimeBar
                android:id="@+id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_10"
                app:bar_height="@dimen/dp_6"
                app:buffered_color="@color/color_unplayer"
                app:layout_constraintBottom_toBottomOf="@+id/exo_position"
                app:layout_constraintTop_toTopOf="@+id/exo_position"
                app:played_color="@color/base_blue"
                app:scrubber_drawable="@color/transparent"
                app:scrubber_enabled_size="@dimen/dp_9"
                app:unplayed_color="@color/color_unplayer"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_video"
                android:gravity="center"
                android:id="@+id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="@dimen/dp_40"
                android:text="00:00"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_video"
                android:gravity="center"
                android:id="@+id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="@dimen/dp_40"
                android:text="24:00"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="end|center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_15">
            <ImageView
                android:id="@+id/iv_mute"
                android:layout_width="@dimen/dp_26"
                android:layout_height="@dimen/dp_26"
                android:src="@drawable/ic_control_unmute"/>
            <ImageView
                android:id="@+id/iv_delete"
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"
                android:src="@drawable/ic_album_delete"
                android:layout_marginStart="@dimen/dp_16"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
