<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_problem_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_20"
        android:layout_marginTop="@dimen/dp_5"
        android:layout_marginRight="@dimen/dp_20"/>
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/no_net_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/dp_14"
            android:textColor="@color/text_important_color_new"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_no_net_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_208"
            android:text="@string/eyevue_loading_no_net_view_text_hint"/>
        <TextView
            android:textSize="@dimen/dp_12"
            android:textColor="@color/gray_828282"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_again"
            android:background="@drawable/shape_button_again"
            android:paddingLeft="2dp"
            android:paddingRight="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minWidth="58dp"
            android:minHeight="30dp"
            android:text="@string/eyevue_loading_no_net_view_again"
            android:layout_below="@+id/tv_no_net_hint"/>
    </LinearLayout>
</LinearLayout>
