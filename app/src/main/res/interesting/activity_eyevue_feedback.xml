<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/type_layout"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_16"
            android:layout_marginHorizontal="@dimen/dp_20">
            <TextView
                android:textSize="@dimen/set_me_function_text_size"
                android:textColor="@color/color_main_text"
                android:textColorHint="@color/color_voice_notes_text"
                android:gravity="center_vertical"
                android:id="@+id/tv_type_tip"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/me_function_height"
                android:text="@string/select_question_type"
                android:drawablePadding="@dimen/dp_10"
                android:paddingStart="@dimen/dp_20"
                android:paddingEnd="@dimen/set_me_function_padding_right"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/color_main_text"
                android:ellipsize="end"
                android:gravity="end"
                android:id="@+id/feedback_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/required"
                android:maxLines="2"
                android:drawablePadding="@dimen/dp_10"
                android:layout_toRightOf="@+id/tv_type_tip"
                android:layout_centerVertical="true"
                android:drawableEnd="@drawable/ic_bv_more"
                android:paddingStart="@dimen/dp_5"
                android:paddingEnd="@dimen/dp_5"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <com.eyevue.common.widget.MyEditText
            android:textSize="16sp"
            android:textColor="@color/color_main_text"
            android:textColorHint="@color/color_voice_notes_text"
            android:gravity="top"
            android:id="@+id/et_comment"
            android:background="@drawable/bg_btn_main"
            android:padding="@dimen/dp_10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:minHeight="220dp"
            android:hint="@string/eyevue_feedback_edit_hint"
            android:maxLength="100"
            android:textCursorDrawable="@null"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_layout"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_20">
            <RelativeLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_55">
                <TextView
                    android:textSize="@dimen/set_me_function_text_size"
                    android:textColor="@color/red_prominence"
                    android:gravity="center_vertical"
                    android:id="@+id/tv_asterisk"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/me_function_height"
                    android:text="*"
                    android:paddingStart="@dimen/dp_20"
                    android:paddingEnd="@dimen/dp_1"/>
                <TextView
                    android:textSize="@dimen/set_me_function_text_size"
                    android:textColor="@color/color_main_text"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/me_function_height"
                    android:text="@string/eyevue_feedback_contact_information"
                    android:paddingEnd="@dimen/dp_10"
                    android:layout_toStartOf="@+id/tv_must_be_transmitted"
                    android:layout_toEndOf="@+id/tv_asterisk"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/red_prominence"
                    android:id="@+id/tv_must_be_transmitted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/must_be_transmitted"
                    android:layout_centerVertical="true"
                    android:paddingEnd="@dimen/dp_20"
                    android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <View
                android:id="@+id/view_line"
                android:background="@color/color_line"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="@dimen/dp_20"/>
            <com.eyevue.common.widget.MyEditText
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_main_text"
                android:textColorHint="@color/tv_hint"
                android:gravity="center_vertical"
                android:id="@+id/contact_title"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_button_height"
                android:hint="@string/eyevue_feedback_contact"
                android:paddingHorizontal="@dimen/dp_20"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:enabled="false"
        android:textSize="@dimen/text_18sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:id="@+id/btn_submit"
        android:background="@drawable/bg_btn_main_base_purple"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50"
        android:layout_marginBottom="@dimen/dp_30"
        android:text="@string/eyevue_feedback_submit"
        android:layout_marginHorizontal="@dimen/dp_20"/>
</LinearLayout>
