<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_marginHorizontal="@dimen/dp_16">
        <ImageView
            android:id="@+id/btn_cancel"
            android:background="@drawable/ic_alarm_cancel"
            android:layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/black"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_alarm_new"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/btn_confirm"
            android:background="@drawable/ic_alarm_confirm"
            android:layout_width="@dimen/dp_32"
            android:layout_height="@dimen/dp_32"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_btn_main"
        android:paddingTop="@dimen/dp_10"
        android:paddingBottom="@dimen/dp_10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginHorizontal="@dimen/dp_16">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/btn_left"
                android:background="@drawable/ic_alarm_left"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_16"/>
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/white"
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/btn_right"
                android:background="@drawable/ic_alarm_right"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_16"
                android:layout_marginEnd="@dimen/dp_16"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <com.haibin.calendarview.CalendarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_10"
            app:calendar_show_mode="only_month_view">
            <com.haibin.calendarview.CalendarView
                android:id="@+id/calendar_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/dp_10"
                app:calendar_height="@dimen/dp_35"
                app:day_text_size="@dimen/sp_14"
                app:month_view="com.eyevue.glassapp.view.alarmclock.GlassesMonthView"
                app:month_view_show_mode="mode_only_current"
                app:week_background="@color/transparent"
                app:week_text_color="@color/white"
                app:week_text_size="@dimen/sp_14"/>
        </com.haibin.calendarview.CalendarLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginHorizontal="@dimen/dp_16">
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/btn_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/set_text_size"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_time_tip"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/ad_icon_height"
                android:text="@string/string_time"
                android:drawablePadding="@dimen/dp_10"
                android:paddingStart="@dimen/dp_15"
                android:paddingEnd="@dimen/set_button_text_padding_right"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textSize="@dimen/tablayout_text_size"
                android:textColor="@color/color_8e"
                android:ellipsize="end"
                android:gravity="end|center_vertical"
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:drawablePadding="@dimen/dp_10"
                android:layout_centerVertical="true"
                android:drawableEnd="@drawable/ic_bv_more"
                android:paddingStart="@dimen/set_button_text_padding_left"
                android:paddingEnd="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_5"
                android:layout_toEndOf="@+id/tv_time_tip"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <View
            android:background="@color/dialog_line"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/btn_repeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/set_text_size"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_repeat_tip"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/ad_icon_height"
                android:text="@string/string_repeat"
                android:drawablePadding="@dimen/dp_10"
                android:paddingStart="@dimen/dp_15"
                android:paddingEnd="@dimen/set_button_text_padding_right"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textSize="@dimen/tablayout_text_size"
                android:textColor="@color/color_8e"
                android:ellipsize="end"
                android:gravity="end|center_vertical"
                android:id="@+id/tv_repeat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:drawablePadding="@dimen/dp_10"
                android:layout_centerVertical="true"
                android:drawableEnd="@drawable/ic_bv_more"
                android:paddingStart="@dimen/set_button_text_padding_left"
                android:paddingEnd="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_5"
                android:layout_toEndOf="@+id/tv_repeat_tip"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
        <View
            android:background="@color/dialog_line"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/set_text_size"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_remarks_tip"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/ad_icon_height"
                android:text="@string/string_remarks"
                android:drawablePadding="@dimen/dp_10"
                android:paddingStart="@dimen/dp_15"
                android:paddingEnd="@dimen/set_button_text_padding_right"
                android:layout_alignParentStart="true"/>
            <EditText
                android:textSize="@dimen/tablayout_text_size"
                android:textColor="@color/color_8e"
                android:textColorHint="@color/color_8e"
                android:ellipsize="end"
                android:id="@+id/et_remarks"
                android:background="@color/transparent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="@string/string_remarks_tip"
                android:singleLine="true"
                android:layout_centerVertical="true"
                android:paddingStart="@dimen/set_button_text_padding_left"
                android:paddingEnd="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_5"
                android:layout_toEndOf="@+id/tv_remarks_tip"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>
    </LinearLayout>
    <RelativeLayout
        android:background="@drawable/bg_btn_main"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginHorizontal="@dimen/dp_16">
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/string_sync_calendar"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_15"/>
        <ImageView
            android:id="@+id/sw_sync_calendar"
            android:background="@drawable/ic_alarm_switch"
            android:layout_width="@dimen/dp_46"
            android:layout_height="@dimen/dp_24"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/dp_16"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</LinearLayout>
