<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/text_18sp"
            android:textStyle="bold"
            android:textColor="@color/color_main_text"
            android:gravity="center"
            android:id="@+id/skip_login"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="@dimen/dp_10"
            android:minWidth="@dimen/dp_50"
            android:text="@string/eyevue_skip"
            android:paddingStart="@dimen/dp_5"
            android:paddingEnd="@dimen/dp_5"
            android:layout_marginEnd="@dimen/dp_16"
            android:layout_alignParentEnd="true"/>
        <com.eyevue.common.widget.BvImageView
            android:id="@+id/image"
            android:layout_width="@dimen/dp_115"
            android:layout_height="@dimen/dp_115"
            android:layout_marginTop="@dimen/dp_110"
            android:src="@drawable/lensiq_logo"
            android:scaleType="fitXY"
            android:layout_centerHorizontal="true"
            app:radius="10dp"/>
        <TextView
            android:textSize="@dimen/text_22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/add_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:text="@string/app_name"
            android:layout_below="@+id/image"
            android:layout_centerHorizontal="true"/>
        <com.eyevue.common.widget.MyEditText
            android:textSize="@dimen/text_14sp"
            android:textColor="@color/color_main_text"
            android:textColorHint="@color/color_voice_notes_text"
            android:id="@+id/et_email"
            android:background="@drawable/bg_edit_auth"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:layout_marginTop="@dimen/dp_24"
            android:hint="@string/eyevue_hint_input_emial"
            android:layout_below="@+id/add_name"
            android:layout_marginHorizontal="@dimen/dp_24"/>
        <RelativeLayout
            android:orientation="horizontal"
            android:id="@+id/sms_layout"
            android:background="@drawable/bg_edit_auth"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:layout_marginTop="@dimen/dp_24"
            android:layout_below="@+id/et_email"
            android:layout_marginHorizontal="@dimen/dp_24">
            <ImageView
                android:id="@+id/show_password"
                android:paddingLeft="@dimen/dp_12"
                android:paddingTop="@dimen/dp_6"
                android:paddingRight="@dimen/dp_12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dp_20"
                android:layout_alignParentEnd="true"/>
            <EditText
                android:textSize="@dimen/text_14sp"
                android:textColor="@color/color_main_text"
                android:textColorHint="@color/color_voice_notes_text"
                android:id="@+id/et_password"
                android:background="@null"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/eyevue_input_password"
                android:layout_centerVertical="true"
                android:imeOptions="actionNext"
                android:textAlignment="viewStart"
                android:layout_toStartOf="@+id/show_password"/>
        </RelativeLayout>
        <TextView
            android:textSize="@dimen/text_12sp"
            android:textColor="@color/color_voice_notes_text"
            android:id="@+id/forget_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_6"
            android:text="@string/eyevue_forget_password"
            android:layout_below="@+id/sms_layout"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignEnd="@+id/sms_layout"/>
        <androidx.appcompat.widget.AppCompatButton
            android:enabled="false"
            android:textSize="@dimen/text_16sp"
            android:textColor="@color/color_main_text"
            android:id="@+id/btn_login"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:layout_marginTop="@dimen/dp_103"
            android:text="@string/eyevue_login"
            android:layout_below="@+id/sms_layout"
            android:textAllCaps="false"
            android:layout_marginHorizontal="@dimen/dp_24"
            style="?android:attr/borderlessButtonStyle"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_16"
            android:layout_below="@+id/btn_login"
            android:layout_centerHorizontal="true">
            <TextView
                android:textSize="@dimen/text_16sp"
                android:textColor="@color/color_voice_notes_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_account"/>
            <TextView
                android:textSize="@dimen/text_16sp"
                android:textColor="@color/color_main_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_now"
                android:layout_marginStart="@dimen/dp_4"/>
        </LinearLayout>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="horizontal"
            android:id="@+id/ll_user_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_20"
            android:layout_alignParentBottom="true"
            android:layout_marginHorizontal="@dimen/dp_33">
            <CheckBox
                android:id="@+id/checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@drawable/selector_checkbox"/>
            <TextView
                android:textSize="@dimen/text_12sp"
                android:textColor="@color/color_voice_notes_text"
                android:id="@+id/tv_content"
                android:paddingBottom="@dimen/dp_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </RelativeLayout>
</FrameLayout>
