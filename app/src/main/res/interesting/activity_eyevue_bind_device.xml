<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/tab_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.eyevue.common.widget.toolbar.ToolBar
            android:id="@+id/title_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.eyevue.common.widget.BvImageView
            android:id="@+id/iv_bind_device_icon"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_187"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_below="@+id/title_bar"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="@dimen/text_18sp"
            android:textStyle="bold"
            android:textColor="@color/text_important_color_new"
            android:gravity="center_horizontal"
            android:id="@+id/bind_device_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_below="@+id/iv_bind_device_icon"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="@dimen/text_16sp"
            android:textStyle="bold"
            android:textColor="@color/white_8F8F8F"
            android:gravity="center_horizontal"
            android:id="@+id/bind_device_mac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_12"
            android:layout_below="@+id/bind_device_name"
            android:layout_centerHorizontal="true"/>
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/qr_code_layout"
            android:background="@drawable/dialog_edit_voice_notes_bg"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_64"
            android:layout_marginTop="@dimen/dp_20"
            android:layout_below="@+id/bind_device_mac"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20">
            <ImageView
                android:id="@+id/scan_code"
                android:background="@drawable/ic_scan_the_code"
                android:layout_width="@dimen/dp_24"
                android:layout_height="@dimen/dp_24"
                android:layout_centerVertical="true"
                android:layout_marginStart="@dimen/dp_12"
                android:layout_marginEnd="@dimen/dp_12"
                android:layout_alignParentEnd="true"/>
            <com.eyevue.common.widget.MyEditText
                android:textSize="@dimen/text_16sp"
                android:textColor="@color/color_voice_notes_text"
                android:textColorHint="@color/white_8F8F8F"
                android:gravity="center_vertical"
                android:id="@+id/edit_bing_code"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/eyevue_edit_authorization_or_qr_code"
                android:layout_centerVertical="true"
                android:textCursorDrawable="@null"
                android:paddingStart="@dimen/dp_16"
                android:layout_marginEnd="@dimen/dp_20"
                android:layout_toStartOf="@+id/scan_code"/>
        </RelativeLayout>
        <androidx.appcompat.widget.AppCompatButton
            android:enabled="false"
            android:textSize="@dimen/text_18sp"
            android:textColor="@drawable/bg_btn_text_selector"
            android:id="@+id/btn_scan_code"
            android:background="@drawable/bg_btn_main"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_56"
            android:layout_marginTop="@dimen/dp_50"
            android:text="@string/eyevue_edit_code_link"
            android:layout_below="@+id/qr_code_layout"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"
            style="?android:attr/borderlessButtonStyle"/>
    </RelativeLayout>
</FrameLayout>
