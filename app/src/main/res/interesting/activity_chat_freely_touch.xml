<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/tab_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_49">
        <ImageView
            android:id="@+id/iv_back_btn"
            android:background="@drawable/ic_search_back"
            android:padding="@dimen/dp_35"
            android:visibility="visible"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/dp_18"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="@color/text_important_color"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/dp_145"
            android:text="@string/trans_phone_tip"
            android:singleLine="true"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_4"
            android:layout_marginEnd="@dimen/dp_4"/>
    </RelativeLayout>
    <RelativeLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/title_layout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_10"
        android:layout_below="@+id/title">
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/text_important_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/btn_from_trans"
            android:background="@drawable/bg_btn_purple_selector"
            android:layout_width="@dimen/dp_128"
            android:layout_height="@dimen/dp_48"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:drawableStart="@drawable/ic_tab_phone"
            android:drawableEnd="@drawable/ic_drop_down"
            android:paddingStart="@dimen/dp_10"
            android:paddingEnd="10dp"
            android:layout_marginStart="@dimen/dp_20"/>
        <TextView
            android:textSize="@dimen/sp_12"
            android:textColor="@color/text_important_color"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/btn_to_trans"
            android:background="@drawable/bg_btn_purple_selector"
            android:layout_width="@dimen/dp_128"
            android:layout_height="@dimen/dp_48"
            android:maxLines="2"
            android:layout_centerVertical="true"
            android:drawableStart="@drawable/ic_tab_phone"
            android:drawableEnd="@drawable/ic_drop_down"
            android:paddingStart="@dimen/dp_10"
            android:paddingEnd="10dp"
            android:layout_marginEnd="@dimen/dp_20"
            android:layout_alignParentEnd="true"/>
        <ImageView
            android:id="@+id/img_exchange"
            android:visibility="visible"
            android:layout_width="@dimen/dp_45"
            android:layout_height="@dimen/dp_48"
            android:src="@drawable/ic_exchange"
            android:layout_centerVertical="true"
            android:paddingStart="@dimen/dp_3"
            android:paddingEnd="@dimen/dp_3"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_10"
            android:layout_toStartOf="@+id/btn_to_trans"
            android:layout_toEndOf="@+id/btn_from_trans"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/rl_bottom"
        android:layout_below="@+id/title_layout">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ai_demo_rc"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/dp_10"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:layout_weight="1"
            android:fadeScrollbars="false"
            android:overScrollMode="never"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/rl_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/buttom_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_50"
            android:layout_marginBottom="@dimen/dp_20"
            android:layout_centerInParent="true"
            android:layout_marginStart="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20">
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/btn_phone_layout"
                android:background="@drawable/btn_base_left"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_48"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/dp_10">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/imageView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_trans_voice"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textStyle="bold"
                    android:textColor="@color/text_important_color"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/btn_phone_voice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="3"
                    android:paddingEnd="@dimen/dp_10"
                    android:layout_marginStart="@dimen/dp_10"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/btn_right_layout"
                android:background="@drawable/btn_base_purple"
                android:layout_width="0dp"
                android:layout_height="@dimen/dp_48"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/dp_10">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/imageViews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_trans_voice_write"/>
                <TextView
                    android:textSize="@dimen/sp_14"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/btn_ear_send"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="3"
                    android:paddingEnd="@dimen/dp_10"
                    android:layout_marginStart="@dimen/dp_10"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_view"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_100"
        android:layout_below="@+id/title_layout">
        <ImageView
            android:id="@+id/img_trans_view"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_200"
            android:layout_marginStart="@dimen/dp_40"
            android:layout_marginEnd="@dimen/dp_40"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_30"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_30">
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/text_important_color"
                android:gravity="center_horizontal"
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_15"
                android:text="@string/ai_tarns_freely_empty"
                android:layout_marginStart="@dimen/dp_25"
                android:layout_marginEnd="@dimen/dp_25"/>
            <TextView
                android:textSize="@dimen/sp_15"
                android:id="@+id/tv_tip"
                android:padding="@dimen/dp_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_20"
                android:layout_marginStart="@dimen/dp_25"
                android:layout_marginEnd="@dimen/dp_25"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@+id/voice_view"
        android:background="@drawable/ai_trans_dialog_gray_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dp_56"
        android:layout_marginRight="@dimen/dp_56"
        android:minHeight="@dimen/dp_140"
        android:layout_centerInParent="true">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/img_voice"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_35"
            android:layout_marginTop="@dimen/dp_8"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_30"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:text="@string/release_to_stop_recording"
            android:layout_marginStart="@dimen/dp_30"
            android:layout_marginEnd="@dimen/dp_30"/>
    </LinearLayout>
    <com.watchfun.transcommon.widget.BottomEditView
        android:id="@+id/bottomEditView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"/>
</RelativeLayout>
