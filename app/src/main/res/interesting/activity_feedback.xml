<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/app_background_color_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.eyevue.common.widget.toolbar.ToolBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <com.eyevue.common.widget.MyEditText
        android:textSize="16sp"
        android:textColor="@color/text_important_color_new"
        android:textColorHint="@color/white_8F8F8F"
        android:gravity="top"
        android:id="@+id/et_comment"
        android:background="@drawable/device_manager_bg"
        android:padding="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:minHeight="220dp"
        android:hint="@string/eyevue_feedback_edit_hint"
        android:maxLength="100"
        android:textCursorDrawable="@null"
        android:textAlignment="viewStart"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20"/>
    <RelativeLayout
        android:id="@+id/other_setting_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/type_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textColor="@color/text_important_color_new"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/home_button_height"
                android:text="@string/eyevue_feedback_type"
                android:drawablePadding="@dimen/dp_5"
                android:paddingStart="@dimen/set_button_text_padding_left"
                android:paddingEnd="@dimen/set_button_text_padding_right"/>
            <TextView
                android:textSize="@dimen/sp_14"
                android:textColor="@color/white_F0F1F5"
                android:gravity="end|center_vertical"
                android:id="@+id/feedback_type"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_button_height"
                android:drawableEnd="@drawable/ic_bv_more"
                android:paddingStart="@dimen/set_button_text_padding_left"
                android:paddingEnd="@dimen/set_button_text_padding_right"/>
        </LinearLayout>
        <View
            android:id="@+id/view_line"
            android:background="@color/dividerColor"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@+id/type_layout"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_18"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/content_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/view_line">
            <com.eyevue.common.widget.MyEditText
                android:textSize="@dimen/sp_16"
                android:textColor="@color/text_important_color_new"
                android:textColorHint="@color/gray_828282"
                android:gravity="center_vertical"
                android:id="@+id/contact_title"
                android:background="@null"
                android:padding="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_button_height"
                android:hint="@string/eyevue_feedback_contact_information"
                android:paddingStart="@dimen/set_button_text_padding_left"
                android:paddingEnd="@dimen/set_button_text_padding_right"/>
        </LinearLayout>
    </RelativeLayout>
    <androidx.appcompat.widget.AppCompatButton
        android:enabled="false"
        android:textSize="@dimen/text_18sp"
        android:textColor="@drawable/bg_btn_text_selector"
        android:id="@+id/btn_submit"
        android:background="@drawable/bg_btn_purple_gray_selector"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_56"
        android:layout_marginTop="@dimen/dp_30"
        android:text="@string/eyevue_feedback_submit"
        android:layout_marginStart="@dimen/dp_20"
        android:layout_marginEnd="@dimen/dp_20"
        style="?android:attr/borderlessButtonStyle"/>
</LinearLayout>
